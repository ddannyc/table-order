/* app.wxss — WeUI 基础样式 + 间距/字号比例（无定制配色） */
@import 'miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

page {
  /* Spacing */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* Radius */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;

  /* Font sizes */
  --font-caption: 24rpx;
  --font-body: 28rpx;
  --font-subhead: 30rpx;
  --font-title: 36rpx;
  --font-h2: 40rpx;
  --font-h1: 48rpx;
  --font-price: 34rpx;
  --font-price-large: 48rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

page, view, text, navigator {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: var(--weui-BG-1);
  padding-bottom: 160rpx;
}

.text-primary { color: var(--weui-BRAND) !important; }
.bg-primary { background: var(--weui-BRAND) !important; }

.card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: var(--weui-FG-2);
  font-size: var(--font-body);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg);
  background: #fff;
  border-bottom: 1rpx solid var(--weui-FG-3);
}

.list-item:last-child {
  border-bottom: none;
}
