/* app.wxss - WeUI 基础样式 + 品牌绿变量 */
@import 'miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

page {
  --weui-primary: #07c160;
  --weui-primary-light: rgba(7, 193, 96, 0.12);
  --weui-color-success: #07c160;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

page, view, text, navigator {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.text-primary { color: #07c160 !important; }
.bg-primary { background: #07c160 !important; }
.text-gold { color: #FFD700 !important; }

.weui-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.submit-btn[disabled] {
  background: #ccc;
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}