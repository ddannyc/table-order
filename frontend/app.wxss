/* app.wxss - WeUI 基础样式 + 设计系统 Token */
@import 'miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

page {
  /* Brand — warm orange (DESIGN.md, from ui-add-food.png) */
  --brand-primary: #F88818;
  --brand-primary-dark: #E0760A;
  --brand-primary-light: rgba(248,136,24,0.12);
  --brand-accent: #F88818;
  --brand-accent-dark: #E0760A;
  --brand-accent-light: rgba(248,136,24,0.12);
  --brand-gradient: linear-gradient(135deg, #F6C84A 0%, #F89A70 100%);

  /* weui overrides — warm orange brand */
  --weui-primary: #F88818;
  --weui-primary-light: rgba(248,136,24,0.12);
  --weui-color-success: #2BA471;

  /* Design Tokens */
  --color-text-primary: #083038;
  --color-text-secondary: rgba(8,48,56,0.60);
  --color-text-hint: rgba(8,48,56,0.35);
  --color-text-disabled: rgba(8,48,56,0.20);
  --color-text-on-brand: #FFFFFF;
  --color-bg-page: #F5F5F5;
  --color-bg-surface: #FFFFFF;
  --color-bg-rail: #F5F5F5;
  --color-bg-hover: #FAF2E8;
  --color-border: rgba(8,48,56,0.08);
  --color-border-light: rgba(8,48,56,0.04);
  --color-price: #083038;
  --color-success: #2BA471;
  --color-danger: #E5484D;
  --color-warning-bg: #fff3cd;
  --color-warning-text: #856404;
  --color-danger-bg: #f8d7da;
  --color-danger-text: #721c24;
  --color-gold: #FFD700;

  /* Spacing */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* Radius */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;

  /* Font sizes */
  --font-caption: 24rpx;
  --font-body: 28rpx;
  --font-subhead: 30rpx;
  --font-title: 36rpx;
  --font-h2: 40rpx;
  --font-h1: 48rpx;
  --font-price: 34rpx;
  --font-price-large: 48rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

page, view, text, navigator {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 160rpx;
}

.text-primary { color: var(--weui-primary) !important; }
.bg-primary { background: var(--weui-primary) !important; }
.text-gold { color: var(--color-gold) !important; }

.card {
  background: var(--color-bg-surface);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-surface);
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: var(--color-text-hint);
  font-size: var(--font-body);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg);
  background: var(--color-bg-surface);
  border-bottom: 1rpx solid var(--color-border-light);
}

.list-item:last-child {
  border-bottom: none;
}