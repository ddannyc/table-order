/* app.wxss — WeUI 基础样式 + 间距/字号比例（无定制配色） */
@import 'miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

page {
  /* 松墨 Pine-Ink 配色（覆盖 weui 变量，须在上方 @import 之后生效）。
     全部值已过 WCAG，详见 docs/ideas/texture-uplift-pine-ink.md / theme-tokens.test.js。 */
  --weui-BRAND: #2C4A3B;   /* 主色：品牌band/主按钮/激活竖条/cartbar/徽章底 */
  --weui-BG-0: #F3EEE4;    /* 页面·燕麦奶油 */
  --weui-BG-1: #FBF8F2;    /* 卡面·近白暖 */
  --weui-BG-2: #EFE9DD;    /* 门店栏/左类目轨底 */
  --weui-FG-0: #2A2723;    /* 正文（12:1） */
  --weui-FG-2: #6E665A;    /* 次要文字（4.89:1，比参考 #8A8275 调暗以过 AA） */
  --weui-FG-3: #E3DCCE;    /* 暖发丝线 */
  --accent: #C8643C;       /* 陶土橙：标签/数量徽章/加购点缀（填充；小字文字对比不足，慎用） */
  --price-ink: #B0491F;    /* 深陶土：价格文字（4.76:1，正文级也过） */

  /* Spacing */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* Radius */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;

  /* Font sizes */
  --font-caption: 24rpx;
  --font-body: 28rpx;
  --font-subhead: 30rpx;
  --font-title: 36rpx;
  --font-h2: 40rpx;
  --font-h1: 48rpx;
  --font-price: 34rpx;
  --font-price-large: 48rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

page, view, text, navigator {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: var(--weui-BG-0);
  padding-bottom: 160rpx;
}

.text-primary { color: var(--weui-BRAND) !important; }
.bg-primary { background: var(--weui-BRAND) !important; }

.card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: var(--weui-FG-2);
  font-size: var(--font-body);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg);
  background: #fff;
  border-bottom: 1rpx solid var(--weui-FG-3);
}

.list-item:last-child {
  border-bottom: none;
}

/* 底部 tabbar 钉底（mp-tabbar 默认非 fixed） */
.tabbar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
}
