/* app.wxss - WeUI 基础样式 + 设计系统 Token */
@import 'miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

page {
  --weui-primary: #07c160;
  --weui-primary-light: rgba(7, 193, 96, 0.12);
  --weui-color-success: #07c160;

  /* Design Tokens */
  --color-text-primary: rgba(0, 0, 0, 0.9);
  --color-text-secondary: rgba(0, 0, 0, 0.55);
  --color-text-hint: rgba(0, 0, 0, 0.3);
  --color-text-disabled: rgba(0, 0, 0, 0.2);
  --color-bg-page: #f5f5f5;
  --color-bg-surface: #fff;
  --color-bg-hover: #f7f7f7;
  --color-border: rgba(0, 0, 0, 0.08);
  --color-border-light: rgba(0, 0, 0, 0.04);
  --color-warning-bg: #fff3cd;
  --color-warning-text: #856404;
  --color-danger-bg: #f8d7da;
  --color-danger-text: #721c24;
  --color-gold: #FFD700;

  /* Spacing */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* Radius */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;

  /* Font sizes */
  --font-caption: 24rpx;
  --font-body: 28rpx;
  --font-subhead: 30rpx;
  --font-title: 36rpx;
  --font-h2: 40rpx;
  --font-h1: 48rpx;
  --font-price: 34rpx;
  --font-price-large: 48rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

page, view, text, navigator {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 160rpx;
}

.text-primary { color: var(--weui-primary) !important; }
.bg-primary { background: var(--weui-primary) !important; }
.text-gold { color: var(--color-gold) !important; }

.card {
  background: var(--color-bg-surface);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-surface);
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: var(--color-text-hint);
  font-size: var(--font-body);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg);
  background: var(--color-bg-surface);
  border-bottom: 1rpx solid var(--color-border-light);
}

.list-item:last-child {
  border-bottom: none;
}