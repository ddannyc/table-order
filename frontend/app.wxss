/* app.wxss — WeUI 基础样式 + 间距/字号比例（无定制配色） */
@import 'miniprogram_npm/weui-miniprogram/weui-wxss/dist/style/weui.wxss';

/* Baloo 2（700 字重）数字子集：仅 0-9 . , + - 等，约 2.8KB base64 内嵌，
   给价格/金额圆体数字质感（设计稿用 Baloo 2）。中文仍走系统黑体。 */
@font-face {
  font-family: 'Baloo2Num';
  src: url('data:font/ttf;base64,') format('truetype');
  font-weight: normal;
  font-style: normal;
}

page {
  /* 鸡福旺 (JFW) 品牌配色（覆盖 weui 变量，须在上方 @import 之后生效）。
     全部值已过 WCAG，详见 tasks/plan.md / theme-tokens.test.js。 */
  /* !important：weui 在更高特异性的 .wx-root 上把 --weui-BRAND 设为亮绿 #07c160，
     仅靠 page 选择器会被盖过（主按钮/cartbar/徽章因此发亮绿）。自定义属性声明加
     !important 即可无视特异性胜出，让整套品牌主色真正生效。其余 BG/FG 令牌 weui
     只定义在 page 上，无此问题。 */
  --weui-BRAND: #FF4896 !important;   /* 主粉：品牌band/主按钮/激活竖条/cartbar/徽章底（填充+大字；大字 on 粉 3.17:1 过 AA-large） */
  --green-2: #D81A60;      /* 深粉：渐变深端 + 承载小号浅色文字（白字 4.96:1 过 AA）。沿用 green-2 槽位避免改名波及 */
  --weui-BG-0: #FBEFF3;    /* 页面·淡粉 */
  --weui-BG-1: #FFFDF8;    /* 卡面·暖近白 */
  --weui-BG-2: #FCE7EF;    /* 门店栏/左类目轨底 */
  --weui-FG-0: #222222;    /* 正文（on 页 14.2:1） */
  --weui-FG-2: #6E646A;    /* 次要文字（on 页 5.07:1 / on 卡 5.59:1，过 AA） */
  --weui-FG-3: #E8E8E8;    /* 分割线 */
  --accent: #FFD300;       /* 亮黄：优惠圈环/装饰（填充；不垫在价格数字下，红字 on 黄仅 3.2:1） */
  --price-ink: #D11414;    /* 价格红：价格文字（on 卡 5.41:1 / on 页 4.90:1，过 AA） */
  /* JFW 新增色（规范扩展，无既有 weui 槽） */
  --jf-blue: #0066FF;      /* 蓝点缀：饮品/链接/边框线 */
  --jf-title-blue: #0A2463; /* # 板块标题（on 卡 14.3:1） */
  --jf-tag-pink: #FFE0ED;  /* 优惠圈底 */
  --jf-tag-red: #C2185B;   /* 优惠圈字（on tag-pink 4.79:1，过 AA） */
  --jf-orange: #FFB829;    /* 饮品/果茶配图主色 */

  /* Spacing */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* Radius */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;

  /* Font sizes */
  --font-caption: 24rpx;
  --font-body: 28rpx;
  --font-subhead: 30rpx;
  --font-title: 36rpx;
  --font-h2: 40rpx;
  --font-h1: 48rpx;
  --font-price: 34rpx;
  --font-price-large: 48rpx;
  --font-number: 'Baloo2Num', -apple-system, BlinkMacSystemFont, sans-serif; /* 价格/金额圆体数字 */

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

page, view, text, navigator {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: var(--weui-BG-0);
  padding-bottom: 160rpx;
}

.text-primary { color: var(--weui-BRAND) !important; }
.bg-primary { background: var(--weui-BRAND) !important; }

.card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.fixed-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: var(--weui-FG-2);
  font-size: var(--font-body);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg);
  background: #fff;
  border-bottom: 1rpx solid var(--weui-FG-3);
}

.list-item:last-child {
  border-bottom: none;
}

/* 底部 tabbar 钉底（mp-tabbar 默认非 fixed） */
.tabbar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
}
