/* 自定义底部 tabbar（v6）。外层 .tabbar-fixed 负责 fixed 定位/白底/安全区，
   本组件只渲染高 100rpx 的图标行（与购物车条 bottom:100rpx 的布局假设一致）。 */
.ctab {
  display: flex;
  height: 100rpx;
  border-top: 1rpx solid #ECE5D7;
}

.ctab-t {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #8A8275;
}

.ctab-t_on {
  color: #234B3A;
  font-weight: 600;
}

/* 线描图标：默认灰，激活态切换为墨绿（颜色已烘焙进 SVG，故两套 data-uri） */
.ctab-ic {
  width: 46rpx;
  height: 46rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.ctab-ic_menu {
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%2024%2024'%20fill%3D'none'%20stroke%3D'%238A8275'%20stroke-width%3D'2'%20stroke-linecap%3D'round'%20stroke-linejoin%3D'round'%3E%3Cpath%20d%3D'M5%209h14l-1.2%2011H6.2z'%2F%3E%3Cpath%20d%3D'M5%209%2012%203l7%206'%2F%3E%3C%2Fsvg%3E");
}
.ctab-t_on .ctab-ic_menu {
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%2024%2024'%20fill%3D'none'%20stroke%3D'%23234B3A'%20stroke-width%3D'2'%20stroke-linecap%3D'round'%20stroke-linejoin%3D'round'%3E%3Cpath%20d%3D'M5%209h14l-1.2%2011H6.2z'%2F%3E%3Cpath%20d%3D'M5%209%2012%203l7%206'%2F%3E%3C%2Fsvg%3E");
}

