/* pages/invite/index.wxss */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 32rpx 32rpx;
  padding: 56rpx 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
}

.stat {
  flex: 1;
  text-align: center;
}

.stat .value {
  font-size: 52rpx;
  font-weight: bold;
}

.stat .label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.share-card {
  text-align: center;
  padding: 56rpx 48rpx;
}

.share-icon {
  width: 128rpx;
  height: 128rpx;
  background: var(--weui-primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  font-size: 80rpx;
}

.share-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.share-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.rules-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.rule-num {
  width: 44rpx;
  height: 44rpx;
  background: var(--weui-primary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.qr-card {
  text-align: center;
  padding: 40rpx 48rpx;
}

.qr-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.qr-image-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.qr-image {
  width: 200rpx;
  height: 200rpx;
}

.qr-desc {
  font-size: 26rpx;
  color: #999;
}

.rule-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  padding-top: 4rpx;
}

.reward-paused-bar {
  background: #fff3cd;
  color: #856404;
  padding: 20rpx 32rpx;
  font-size: 24rpx;
}