/* pages/invite/index.wxss */
.header-card {
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-dark) 100%);
  border-radius: 0 0 32rpx 32rpx;
  padding: 56rpx 32rpx;
  color: var(--color-bg-surface);
  margin-bottom: var(--space-md);
}

.stats-row {
  display: flex;
}

.stat {
  flex: 1;
  text-align: center;
}

.stat .value {
  font-size: 52rpx;
  font-weight: bold;
}

.stat .label {
  font-size: var(--font-caption);
  opacity: 0.8;
  margin-top: var(--space-xs);
}

.share-card {
  text-align: center;
  padding: 56rpx 48rpx;
}

.share-icon {
  width: 128rpx;
  height: 128rpx;
  background: var(--weui-primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  font-size: 80rpx;
}

.share-title {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.share-desc {
  font-size: var(--font-body);
  color: var(--color-text-hint);
  margin-bottom: var(--space-xl);
}

.rules-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-lg);
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
}

.rule-num {
  width: 44rpx;
  height: 44rpx;
  background: var(--weui-primary);
  color: var(--color-bg-surface);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-caption);
  font-weight: bold;
  flex-shrink: 0;
}

.qr-card {
  text-align: center;
  padding: 40rpx 48rpx;
}

.qr-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-lg);
}

.qr-image-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.qr-image {
  width: 200rpx;
  height: 200rpx;
}

.qr-desc {
  font-size: 26rpx;
  color: var(--color-text-hint);
}

.rule-text {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
  line-height: 1.5;
  padding-top: 4rpx;
}

.reward-paused-bar {
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
  padding: 20rpx 32rpx;
  font-size: var(--font-caption);
}

/* 未登录提示 */
.login-tip-inline {
  text-align: center;
  padding: 40rpx 48rpx;
}

.login-tip-text {
  display: block;
  font-size: var(--font-body);
  color: var(--color-text-hint);
  margin-bottom: var(--space-lg);
}

.login-tip-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: var(--weui-primary);
  color: var(--color-bg-surface);
  font-size: var(--font-body);
  border-radius: var(--radius-sm);
}