<!-- pages/invite/index.wxml -->
<view class="page">
  <!-- Header Stats -->
  <view class="header-card">
    <view class="stats-row">
      <view class="stat">
        <view class="value">{{stats.invite_count}}</view>
        <view class="label">邀请人数</view>
      </view>
      <view class="stat">
        <view class="value">{{statsText.totalInviteReward}}</view>
        <view class="label">累计奖励</view>
      </view>
      <view class="stat">
        <view class="value">{{statsText.todayReward}}</view>
        <view class="label">今日奖励</view>
      </view>
    </view>
  </view>

  <!-- Reward Paused Warning -->
  <view wx:if="{{rewardPaused}}" class="reward-paused-bar">
    账户连续90天未消费，返利已暂停。消费一笔即可恢复。
  </view>

  <!-- Share Card -->
  <view class="share-card card">
    <view class="share-icon">
      <text class="share-icon-text">礼</text>
    </view>
    <view class="share-title">邀请好友赚福利金币</view>
    <view class="share-desc">直推10% · 间推4% · 自购3%</view>

    <button class="weui-btn" type="primary" open-type="share">分享到微信</button>
    <button class="weui-btn weui-btn_default" bind:tap="goShareCode" style="margin-top:16rpx">我的推广码</button>
  </view>

  <!-- 邀请二维码 -->
  <view class="qr-card card" wx:if="{{qrCodeSrc}}">
    <view class="qr-title">邀请二维码</view>
    <view class="qr-image-wrap">
      <image class="qr-image" src="{{qrCodeSrc}}" mode="widthFix" />
    </view>
    <view class="qr-desc">扫一扫二维码，加入我的邀请</view>
  </view>

  <!-- Rules -->
  <view class="rules-card card">
    <view class="rules-title">福利金币规则</view>
    <view class="rules-list">
      <view class="rule-item">
        <view class="rule-num">自</view>
        <view class="rule-text">自购返利 3% — 自己消费得订单金额3%金币</view>
      </view>
      <view class="rule-item">
        <view class="rule-num">1</view>
        <view class="rule-text">直推奖励 10% — 一级好友消费得10%金币</view>
      </view>
      <view class="rule-item">
        <view class="rule-num">2</view>
        <view class="rule-text">间推奖励 4% — 二级好友消费得4%金币</view>
      </view>
      <view class="rule-item">
        <view class="rule-num">抵</view>
        <view class="rule-text">金币可抵扣订单金额最高50%，有效期180天</view>
      </view>
    </view>
  </view>

  <!-- 底部tabbar -->
  <custom-tab-bar current="{{tabbar.current}}" bindchange="tabChange" list="{{tabbar.list}}" />
</view>