/* pages/menu/index.wxss — 点餐菜单页（weui 原生） */
.menu-main {
  padding-bottom: 240rpx; /* 让最后的菜品不被购物车条 + tabbar 遮挡 */
}

/* 门店栏 + 堂食/外卖切换 */
.menu-shopbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) var(--space-lg);
  background: var(--weui-BG-2);
}

.menu-shopname {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-typetoggle {
  display: flex;
  gap: var(--space-xs);
  flex: none;
}

/* 分类页签：横向滚动 navbar，吸顶 */
.menu-navbar {
  position: sticky;
  top: 0;
  z-index: 10;
  white-space: nowrap;
  background: var(--weui-BG-2);
}
.menu-navbar .weui-navbar__item {
  display: inline-block;
  width: auto;
  padding: 0 var(--space-lg);
}

.menu-panel {
  margin: 0;
}

/* 菜品行底部：价格 + 操作 */
.menu-row-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-xs);
}

.menu-price {
  font-size: var(--font-price);
  font-weight: 600;
  color: var(--weui-FG-0);
}

.menu-price-from {
  font-size: var(--font-caption);
  font-weight: 400;
  margin-left: 2rpx;
  color: var(--weui-FG-2);
}

.menu-action {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.menu-stepper {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.menu-qty {
  min-width: 40rpx;
  text-align: center;
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}

.menu-qbadge {
  font-size: var(--font-caption);
  color: var(--weui-BRAND);
}

.menu-soldout {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

/* 购物车结算条（tabbar 之上） */
.menu-cartbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-lg);
  background: var(--weui-BG-1);
  border-top: 1rpx solid var(--weui-FG-3);
  z-index: 20;
}

.menu-cart-summary {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}

.menu-cart-go {
  flex: none;
}

/* 规格弹层价格/按钮 */
.menu-spec-price {
  color: var(--weui-FG-0);
}
.menu-spec-add {
  margin-left: var(--space-md);
}
