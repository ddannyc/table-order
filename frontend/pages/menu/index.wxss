/* pages/menu/index.wxss — 点餐菜单页（weui 原生）。分类占位插画见 menu-art.wxss。 */
@import './menu-art.wxss';

.menu-main {
  /* 左右布局自身按视口高度铺满；底部留白由右侧列表负责 */
}

/* 品牌海报头（粉底，对齐设计稿：#鸡福旺 + 现炸出炉 + 标语药丸） */
.menu-poster {
  height: 160rpx;
  box-sizing: border-box;
  background: var(--weui-BRAND);
  padding: 16rpx 24rpx 18rpx;
}
.menu-poster-row {
  display: flex;
  align-items: center;
}
.menu-poster-brand {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  color: #fff;
  line-height: 1.15;
}
.menu-poster-tag {
  margin-left: auto;
  background: var(--accent);
  color: var(--jf-tag-red);
  font-size: 20rpx;
  font-weight: 900;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
.menu-poster-sub {
  margin-top: 10rpx;
  display: inline-block;
  background: #fff;
  color: var(--jf-title-blue);
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

/* # 板块标题（深蓝 + 粉 #，对齐设计稿） */
.menu-sec {
  display: flex;
  align-items: baseline;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--jf-title-blue);
  padding: var(--space-sm) 0 var(--space-md);
}
.menu-sec::before {
  content: "#";
  color: var(--weui-BRAND);
  font-weight: 800;
  margin-right: 6rpx;
}

/* 未绑桌空状态：单线空碗插画（陶土橙描边，与 --accent 同源） */
.menu-empty-illu {
  width: 200rpx;
  height: 168rpx;
  margin: 0 auto;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%20120%20100'%20fill%3D'none'%20stroke%3D'%23FF4896'%20stroke-width%3D'3'%20stroke-linecap%3D'round'%20stroke-linejoin%3D'round'%3E%3Cellipse%20cx%3D'60'%20cy%3D'54'%20rx%3D'32'%20ry%3D'8'%2F%3E%3Cpath%20d%3D'M30%2054q30%2036%2060%200'%2F%3E%3Cpath%20d%3D'M38%2040l46-12M40%2047l46-12'%2F%3E%3Cpath%20d%3D'M58%2022q-5-7%200-13M70%2020q4-5%200-10'%2F%3E%3C%2Fsvg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

/* 门店栏：白底 + 绿定位针 + 店名 + 绿色点餐方式药丸（对齐 v6 设计稿） */
.menu-shopbar {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-md) var(--space-lg);
  background: var(--weui-BG-1);
}

/* 绿色定位针图标（线描，data-uri 自包含） */
.menu-shop-pin {
  flex: none;
  width: 30rpx;
  height: 30rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%2024%2024'%20fill%3D'none'%20stroke%3D'%23FF4896'%20stroke-width%3D'2'%20stroke-linecap%3D'round'%20stroke-linejoin%3D'round'%3E%3Cpath%20d%3D'M20%2010c0%206-8%2012-8%2012s-8-6-8-12a8%208%200%200%201%2016%200z'%2F%3E%3Ccircle%20cx%3D'12'%20cy%3D'10'%20r%3D'3'%2F%3E%3C%2Fsvg%3E");
}

.menu-shopname {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--weui-FG-0);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 点餐方式：深绿实心药丸（照搬 v6 设计稿右上角标签） */
.menu-mode {
  flex: none;
  margin-left: var(--space-sm);
  font-size: var(--font-caption);
  color: #fff;
  background: var(--weui-BRAND);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-lg);
  font-weight: 600;
}

/* 左右布局：左类目轨 + 右大图卡片，各自独立滚动 */
.menu-body {
  display: flex;
  height: calc(100vh - 96rpx - 160rpx); /* 减去门店栏 + 海报头，左右轨独立滚动 */
}

/* 左：竖向类目轨 */
.menu-rail {
  flex: none;
  width: 180rpx;
  height: 100%;
  background: var(--weui-BG-2);
}

.menu-rail-item {
  min-height: 88rpx; /* a11y：触控目标 ≥ 80rpx */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  padding: var(--space-xs) var(--space-md);
  font-size: var(--font-body);
  color: var(--weui-FG-1);
  border-left: 6rpx solid transparent; /* 激活竖条占位，避免跳动 */
}

/* 类目菜品数徽章：陶土橙药丸 + 白字（照搬 v6 设计稿，真数据） */
.menu-rail-count {
  min-width: 26rpx;
  margin-top: 6rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  line-height: 30rpx;
  text-align: center;
  color: #fff;
  background: var(--accent);
  border-radius: 16rpx;
}

/* 激活态（页面唯一亮点）：绿竖条 + 白底凸出 + 加粗，不只靠颜色 */
.menu-rail-item_on {
  background: var(--weui-BG-1); /* 近白凸出，对比左轨 BG-2 */
  color: var(--weui-FG-0);
  font-weight: 600;
  border-left-color: var(--weui-BRAND);
}

/* 右：大图卡片列表（淡粉底，白卡浮于其上，对齐设计稿） */
.menu-list {
  flex: 1;
  height: 100%;
  background: var(--weui-BG-0);
  padding: var(--space-sm) var(--space-md) 220rpx; /* 底部留白避开购物车条 + tabbar */
}

/* 浮起的白色圆角卡片（对齐设计稿：白卡 + 圆角 + 粉调柔投影，卡间留白） */
.menu-card {
  display: flex;
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
  background: var(--weui-BG-1);
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 16rpx rgba(255, 72, 150, 0.08);
}

/* 缩略图：真实图或 CSS 占位块（同尺寸，避免布局跳动） */
.menu-card-thumb {
  flex: none;
  width: 160rpx;
  height: 160rpx;
  margin-right: var(--space-md);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.menu-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 展位图：暖底 + 彩色饮品插画（见 menu-art.wxss）。设计过的占位（非空块），
   无真照片时也不显空。有 product.image（OSS）时此块不出现。分类标签作底部 caption。 */
.menu-thumb-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: var(--space-xs);
  background-color: #FBE9F0; /* 暖底 */
  border: 1rpx solid var(--weui-FG-3);
  color: var(--price-ink);
  font-size: var(--font-caption);
}

.menu-card-bd {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0; /* 允许文本省略 */
}
.menu-card-title {
  font-size: var(--font-subhead);
  font-weight: 600;
  color: var(--weui-FG-0);
}
.menu-card-desc {
  margin-top: var(--space-xs);
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片底部：价格 + 操作（撑到底部对齐） */
.menu-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: var(--space-sm);
}

/* 尊重系统“减弱动态效果” */
@media (prefers-reduced-motion: reduce) {
  .menu-rail-item,
  .menu-card {
    transition: none;
  }
}

/* 黄底红字价格标（对齐设计稿；大字粗体数字 on 黄 3.2:1 过大字阈值） */
.menu-price {
  display: inline-flex;
  align-items: baseline;
  background: var(--accent);
  color: var(--price-ink);
  font-size: var(--font-price);
  font-weight: 700;
  font-family: var(--font-number);
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
}

.menu-price-from {
  font-size: var(--font-caption);
  font-weight: 400;
  margin-left: 2rpx;
  color: var(--price-ink);
}

.menu-action {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

/* 圆形加购按钮（深绿实心 + 纯白 + + 柔投影），照搬 v6 设计稿 */
.menu-add-round {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--weui-BRAND);
  color: #fff;
  font-size: 42rpx;
  line-height: 56rpx;
  text-align: center;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(35, 75, 58, 0.25);
}

.menu-stepper {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.menu-qty {
  min-width: 40rpx;
  text-align: center;
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}

.menu-qbadge {
  font-size: var(--font-caption);
  color: var(--weui-BRAND);
}

.menu-soldout {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

/* 购物车结算条（tabbar 之上）：深松绿渐变压场（对齐 v6 设计稿） */
.menu-cartbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-lg);
  background: linear-gradient(120deg, var(--weui-BRAND), var(--green-2));
  z-index: 20;
}

/* 左侧：圆形车标 + 价格强调 + 已选件数副行 */
.menu-cart-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.menu-cart-icon {
  flex: none;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}
.menu-cart-sum {
  display: flex;
  flex-direction: column;
}
.menu-cart-total {
  font-size: var(--font-price);
  font-weight: 800;
  font-family: var(--font-number);
  color: var(--weui-BG-0); /* 奶油字 */
  line-height: 1.1;
}
.menu-cart-count {
  font-size: var(--font-caption);
  color: var(--weui-BG-0);
  opacity: 0.8;
}

/* 去结算：陶土橙药丸（照搬 v6 设计稿，绿底上的暖色行动点） */
.menu-cart-go {
  flex: none;
  background: var(--accent);
  color: var(--jf-title-blue); /* 深蓝字 on 亮黄，对比度达标且对齐设计稿 */
  font-weight: 700;
  font-size: var(--font-body);
  padding: 18rpx 44rpx;
  border-radius: 44rpx;
}

/* 规格弹层价格/按钮 */
.menu-spec-price {
  color: var(--weui-FG-0);
}
.menu-spec-add {
  margin-left: var(--space-md);
}
