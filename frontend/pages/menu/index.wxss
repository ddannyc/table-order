/* pages/menu/index.wxss — 点餐菜单页（weui 原生）。分类占位插画见 menu-art.wxss。 */
@import './menu-art.wxss';

.menu-main {
  /* 左右布局自身按视口高度铺满；底部留白由右侧列表负责 */
}

/* 品牌海报头（粉底，对齐设计稿：#鸡福旺 + 现炸出炉 + 标语药丸） */
.menu-poster {
  height: 184rpx;
  box-sizing: border-box;
  background: var(--weui-BRAND);
  padding: 18rpx 24rpx 20rpx;
}
.menu-poster-row {
  display: flex;
  align-items: center;
}
.menu-poster-brand {
  font-size: 60rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  color: #fff;
  line-height: 1.1;
  text-shadow: 3rpx 5rpx 0 var(--green-2); /* 深粉立体投影（补足无庆科黄油体的活泼感） */
}
.menu-poster-tag {
  margin-left: auto;
  background: var(--accent);
  color: var(--jf-tag-red);
  font-size: 20rpx;
  font-weight: 900;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
.menu-poster-sub {
  margin-top: 10rpx;
  display: inline-block;
  background: #fff;
  color: var(--jf-title-blue);
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

/* # 板块标题（深蓝 + 粉 # + 蓝色横线填充整行，对齐设计稿） */
.menu-sec {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0 var(--space-md);
}
.menu-sec-t {
  flex: none;
  font-size: 34rpx;
  font-weight: 900;
  color: var(--jf-title-blue);
}
.menu-sec-t::before {
  content: "#";
  color: var(--weui-BRAND);
  font-weight: 900;
  margin-right: 4rpx;
}
.menu-sec-line {
  flex: 1;
  height: 6rpx;
  background: var(--jf-blue); /* 蓝色点缀横线 */
  border-radius: 3rpx;
  opacity: 0.85;
}

/* 未绑桌空状态：单线空碗插画（品牌粉描边） */
.menu-empty-illu {
  width: 200rpx;
  height: 168rpx;
  margin: 0 auto;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%20120%20100'%20fill%3D'none'%20stroke%3D'%23FF4896'%20stroke-width%3D'3'%20stroke-linecap%3D'round'%20stroke-linejoin%3D'round'%3E%3Cellipse%20cx%3D'60'%20cy%3D'54'%20rx%3D'32'%20ry%3D'8'%2F%3E%3Cpath%20d%3D'M30%2054q30%2036%2060%200'%2F%3E%3Cpath%20d%3D'M38%2040l46-12M40%2047l46-12'%2F%3E%3Cpath%20d%3D'M58%2022q-5-7%200-13M70%2020q4-5%200-10'%2F%3E%3C%2Fsvg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

/* 门店栏：透明底 + 粉圆白针定位 + 店名 + 浅粉底深粉字点餐方式药丸 */
.menu-shopbar {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md) var(--space-lg) var(--space-sm);
  background: transparent; /* 坐在页面粉底上，对齐设计稿 */
}

/* 定位针：粉色实心圆 + 白色线针（对齐设计稿） */
.menu-shop-pin {
  flex: none;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: var(--weui-BRAND);
  background-repeat: no-repeat;
  background-position: center;
  background-size: 22rpx 22rpx;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%2024%2024'%20fill%3D'none'%20stroke%3D'%23fff'%20stroke-width%3D'2.4'%20stroke-linecap%3D'round'%20stroke-linejoin%3D'round'%3E%3Cpath%20d%3D'M20%2010c0%206-8%2012-8%2012s-8-6-8-12a8%208%200%200%201%2016%200z'%2F%3E%3Ccircle%20cx%3D'12'%20cy%3D'10'%20r%3D'3'%2F%3E%3C%2Fsvg%3E");
}

.menu-shopname {
  font-size: var(--font-subhead);
  font-weight: 900;
  color: var(--weui-FG-0);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 点餐方式：浅粉底 + 深粉字药丸（对齐设计稿） */
.menu-mode {
  flex: none;
  margin-left: var(--space-sm);
  font-size: var(--font-caption);
  color: var(--jf-tag-red);
  background: var(--jf-tag-pink);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-lg);
  font-weight: 800;
}

/* 左右布局：左类目轨 + 右大图卡片，各自独立滚动 */
.menu-body {
  display: flex;
  height: calc(100vh - 96rpx - 184rpx); /* 减去门店栏 + 海报头，左右轨独立滚动 */
}

/* 左：竖向类目轨 */
.menu-rail {
  flex: none;
  width: 180rpx;
  height: 100%;
  background: var(--weui-BG-2);
}

.menu-rail-item {
  min-height: 88rpx; /* a11y：触控目标 ≥ 80rpx */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  padding: var(--space-xs) var(--space-md);
  font-size: var(--font-body);
  color: var(--weui-FG-1);
  border-left: 6rpx solid transparent; /* 激活竖条占位，避免跳动 */
}

/* 类目菜品数徽章：亮黄药丸 + 深蓝字（真数据；白字 on 黄不可读） */
.menu-rail-count {
  min-width: 26rpx;
  margin-top: 6rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  line-height: 30rpx;
  text-align: center;
  color: var(--jf-title-blue); /* 深蓝字 on 亮黄（≈11:1）；白字 on 黄仅 1.44:1 不可读 */
  background: var(--accent);
  border-radius: 16rpx;
}

/* 激活态：粉竖条 + 白底凸出 + 加粗，不只靠颜色 */
.menu-rail-item_on {
  background: var(--weui-BG-1); /* 近白凸出，对比左轨 BG-2 */
  color: var(--weui-FG-0);
  font-weight: 600;
  border-left-color: var(--weui-BRAND);
}

/* 右：大图卡片列表（淡粉底，白卡浮于其上，对齐设计稿） */
.menu-list {
  flex: 1;
  height: 100%;
  background: var(--weui-BG-0);
  padding: var(--space-sm) var(--space-md) 220rpx; /* 底部留白避开购物车条 + tabbar */
}

/* 浮起的白色圆角卡片（对齐设计稿：白卡 + 圆角 + 粉调柔投影，卡间留白） */
.menu-card {
  display: flex;
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
  background: var(--weui-BG-1);
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 16rpx rgba(255, 72, 150, 0.08);
}

/* 缩略图：真实图或 CSS 占位块（同尺寸，避免布局跳动） */
.menu-card-thumb {
  flex: none;
  width: 160rpx;
  height: 160rpx;
  margin-right: var(--space-md);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.menu-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 展位图：暖底 + 彩色饮品插画（见 menu-art.wxss）。设计过的占位（非空块），
   无真照片时也不显空。有 product.image（OSS）时此块不出现。分类标签作底部 caption。 */
.menu-thumb-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: var(--space-xs);
  background-color: #FBE9F0; /* 暖底 */
  border: 1rpx solid var(--weui-FG-3);
  color: var(--price-ink);
  font-size: var(--font-caption);
}

.menu-card-bd {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0; /* 允许文本省略 */
}
.menu-card-title {
  font-size: var(--font-subhead);
  font-weight: 900;
  color: var(--weui-FG-0);
}
.menu-card-desc {
  margin-top: var(--space-xs);
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片底部：价格 + 操作（撑到底部对齐） */
.menu-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: var(--space-sm);
}

/* 尊重系统“减弱动态效果” */
@media (prefers-reduced-motion: reduce) {
  .menu-rail-item,
  .menu-card {
    transition: none;
  }
}

/* 黄底红字价格标（对齐设计稿；大字粗体数字 on 黄 3.2:1 过大字阈值） */
.menu-price {
  display: inline-flex;
  align-items: baseline;
  background: var(--accent);
  color: var(--price-ink);
  font-size: var(--font-price);
  font-weight: 800;
  font-family: var(--font-number);
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  box-shadow: 0 4rpx 0 #E0B900; /* 黄色立体底影，对齐设计稿 */
}

.menu-price-from {
  font-size: var(--font-caption);
  font-weight: 400;
  margin-left: 2rpx;
  color: var(--price-ink);
}

.menu-action {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

/* 圆形加购按钮（品牌粉实心 + 纯白 + + 柔投影） */
.menu-add-round {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--weui-BRAND);
  color: #fff;
  font-size: 42rpx;
  line-height: 56rpx;
  text-align: center;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(255, 72, 150, 0.25);
}

.menu-stepper {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

/* 加减器：粉边圆按钮（对齐设计稿，替代 weui 灰按钮） */
.menu-step-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid var(--weui-BRAND);
  background: #fff;
  color: var(--weui-BRAND);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 50rpx;
  text-align: center;
}

.menu-qty {
  min-width: 40rpx;
  text-align: center;
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}

.menu-qbadge {
  font-size: var(--font-caption);
  color: var(--weui-BRAND);
}

.menu-soldout {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

/* 购物车结算条：浮动粉色药丸（内缩 + 大圆角 + 实心粉，对齐设计稿） */
.menu-cartbar {
  position: fixed;
  left: var(--space-md);
  right: var(--space-md);
  bottom: calc(100rpx + env(safe-area-inset-bottom) + 16rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-sm) var(--space-sm) var(--space-lg);
  background: var(--weui-BRAND);
  border-radius: 56rpx;
  box-shadow: 0 12rpx 28rpx rgba(255, 72, 150, 0.4);
  z-index: 20;
}

/* 左侧：圆形车标 + 价格强调 + 已选件数副行 */
.menu-cart-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.menu-cart-icon {
  flex: none;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--accent); /* 黄底车标，对齐设计稿 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}
.menu-cart-sum {
  display: flex;
  flex-direction: column;
}
.menu-cart-total {
  font-size: var(--font-price);
  font-weight: 800;
  font-family: var(--font-number);
  color: #fff;
  line-height: 1.1;
}
.menu-cart-count {
  font-size: var(--font-caption);
  color: #fff;
  opacity: 0.9;
}

/* 去结算：亮黄药丸 + 深蓝字（粉色车条上的行动点） */
.menu-cart-go {
  flex: none;
  background: var(--accent);
  color: var(--jf-title-blue); /* 深蓝字 on 亮黄，对比度达标且对齐设计稿 */
  font-weight: 900;
  font-size: var(--font-body);
  padding: 18rpx 44rpx;
  border-radius: 44rpx;
}

/* ===== 规格选择弹层（底部 sheet：商品头 + 单选药丸 + 价/步进 + 整宽加入） ===== */
.spec-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 110; /* 高于钉底 tabbar(z-index:100)，否则加入按钮被遮挡 */
}
.spec-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 111;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx var(--space-lg) calc(var(--space-lg) + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 28rpx rgba(0, 0, 0, 0.12);
  overflow: hidden; /* 让整宽封面图被 sheet 顶部圆角裁切 */
}
/* 整宽封面图：负边距抵消 sheet padding，铺满顶部至圆角；底部渐隐入白接住标题 */
.spec-cover {
  position: relative;
  margin: -16rpx calc(-1 * var(--space-lg)) 0;
  height: 280rpx;
  overflow: hidden;
}
.spec-cover-img {
  width: 100%;
  height: 100%;
}
.spec-cover-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-h2);
  font-weight: 800;
  color: var(--jf-title-blue);
}
.spec-cover-fade {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.12), rgba(0, 0, 0, 0) 40%, rgba(255, 255, 255, 0) 72%, #fff);
}
.spec-cover-x {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.42);
  color: #fff;
  font-size: 26rpx;
}
.spec-hd {
  margin-top: var(--space-sm);
}
.spec-name {
  font-size: var(--font-h2);
  font-weight: 800;
  color: var(--jf-title-blue);
}
.spec-desc {
  margin-top: 6rpx;
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.spec-group {
  margin-top: var(--space-lg);
}
.spec-group-t {
  font-size: var(--font-body);
  font-weight: 700;
  color: var(--jf-title-blue);
}
.spec-group-t::before {
  content: "#";
  color: var(--weui-BRAND);
  font-weight: 900;
  margin-right: 6rpx;
}
.spec-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}
/* 规格药丸：默认浅灰描边；选中=品牌粉实心；售罄=禁用灰 */
.spec-pill {
  padding: 14rpx 28rpx;
  border-radius: 32rpx; /* 圆角矩形(≈设计16px)，非满胶囊 */
  border: 2rpx solid var(--weui-FG-3);
  background: #fff;
  color: var(--weui-FG-0);
  font-size: var(--font-body);
}
.spec-pill-p {
  margin-left: 8rpx;
  font-family: var(--font-number);
  font-size: var(--font-caption);
  opacity: 0.85;
}
.spec-pill_on {
  background: var(--weui-BRAND);
  border-color: var(--weui-BRAND);
  color: #fff;
}
.spec-pill_off {
  color: var(--weui-FG-3);
  border-style: dashed;
  text-decoration: line-through;
}

.spec-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-lg);
}
.spec-price {
  font-family: var(--font-number);
  font-size: var(--font-price);
  font-weight: 800;
  color: var(--weui-BRAND);
}
.spec-price-cur {
  font-size: var(--font-body);
  margin-right: 2rpx;
}
.spec-stepper {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

/* 整宽 + 胶囊圆边：weui-btn 自带居中收缩(同优先级)且 8px 方角，用后代选择器提优先级覆盖 */
.spec-sheet .spec-add {
  width: 100%;
  margin: var(--space-lg) 0 0;
  border-radius: 50rpx; /* ≈设计25px 胶囊圆边 */
  box-sizing: border-box;
}
.spec-add[disabled] {
  opacity: 0.5;
}

/* ===== 购物车弹层（已选商品面板：逐行改量 / 清空 / 去结算） ===== */
.cart-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 110; /* 高于钉底 tabbar(z-index:100) */
}
.cart-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 111;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: var(--space-lg) var(--space-lg) calc(var(--space-md) + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 28rpx rgba(0, 0, 0, 0.12);
}
.cart-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}
.cart-hd-t {
  font-size: var(--font-h2);
  font-weight: 800;
  color: var(--jf-title-blue);
}
.cart-clear {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}
.cart-rows {
  max-height: 52vh;
}
.cart-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  border-bottom: 2rpx solid var(--weui-FG-4, #f0f0f0);
}
.cart-row-thumb {
  flex: none;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: var(--accent);
}
.cart-row-img {
  width: 100%;
  height: 100%;
}
.cart-row-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  color: var(--jf-title-blue);
}
.cart-row-bd {
  flex: 1;
  min-width: 0;
}
.cart-row-name {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}
.cart-row-spec {
  margin-top: 4rpx;
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}
.cart-row-price {
  flex: none;
  margin-right: var(--space-sm);
  font-family: var(--font-number);
  font-weight: 800;
  color: var(--weui-BRAND);
}
.cart-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-lg);
}
.cart-foot-sum {
  font-size: var(--font-body);
  color: var(--weui-FG-1);
}
.cart-foot-total {
  font-family: var(--font-number);
  font-size: var(--font-price);
  font-weight: 800;
  color: var(--weui-BRAND);
}
.cart-foot-go {
  flex: none;
  background: var(--weui-BRAND);
  color: #fff;
  font-weight: 900;
  font-size: var(--font-body);
  padding: 18rpx 56rpx;
  border-radius: 44rpx;
}
