<!-- pages/menu/index.wxml — 点餐菜单页（weui 原生） -->
<view class="page">

  <!-- 未绑桌 -->
  <view wx:if="{{!boundShopId && !loading}}" class="weui-msg">
    <view class="weui-msg__icon-area">
      <view class="menu-empty-illu" aria-hidden="true"></view>
    </view>
    <view class="weui-msg__text-area">
      <view class="weui-msg__title">未绑定桌号</view>
      <view class="weui-msg__desc">请扫描餐桌二维码开始点餐</view>
    </view>
    <view class="weui-msg__opr-area">
      <view class="weui-btn-area">
        <button class="weui-btn weui-btn_primary" bind:tap="scanQR">扫码点餐</button>
        <button class="weui-btn" type="default" bind:tap="goHome">返回首页</button>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:elif="{{loading}}" class="weui-loadmore">
    <view class="weui-loading"></view>
    <view class="weui-loadmore__tips">加载中…</view>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{error}}" class="weui-msg">
    <view class="weui-msg__text-area">
      <view class="weui-msg__title">加载失败</view>
      <view class="weui-msg__desc">网络开小差了，请重试</view>
    </view>
    <view class="weui-msg__opr-area">
      <view class="weui-btn-area">
        <button class="weui-btn weui-btn_primary" bind:tap="onRetry">重新加载</button>
      </view>
    </view>
  </view>

  <!-- 空菜单 -->
  <view wx:elif="{{products.length === 0}}" class="weui-msg">
    <view class="weui-msg__text-area">
      <view class="weui-msg__title">暂无菜品</view>
      <view class="weui-msg__desc">该店铺还没有上架菜品</view>
    </view>
  </view>

  <!-- 菜单主体 -->
  <view wx:else class="menu-main">

    <!-- 品牌海报头（对齐设计稿：#鸡福旺 + 现炸出炉 + 标语药丸） -->
    <view class="menu-poster">
      <view class="menu-poster-row">
        <view class="menu-poster-brand">#鸡福旺</view>
        <view class="menu-poster-tag">现炸出炉</view>
      </view>
      <view class="menu-poster-sub">五指毛桃鸡 · 鲜烤窑鸡 · 现炸零食小食</view>
    </view>

    <!-- 门店栏 + 只读点餐方式（单型在首页唯一入口确定，菜单内不可切换） -->
    <view class="menu-shopbar">
      <view class="menu-shop-pin" aria-hidden="true"></view>
      <view class="menu-shopname">{{shop.name || '店铺'}}</view>
      <view class="menu-mode">{{orderType === 'delivery' ? '外卖 · 送货上门' : '堂食 · ' + boundTableNo}}</view>
    </view>

    <!-- 左右布局：左类目轨 + 右大图卡片 -->
    <view class="menu-body">

      <!-- 左：竖向类目轨（激活态粉竖条） -->
      <scroll-view scroll-y class="menu-rail" enable-flex>
        <view
          wx:for="{{categories}}"
          wx:key="this"
          class="menu-rail-item {{activeCategory === item ? 'menu-rail-item_on' : ''}}"
          bindtap="selectCategory"
          data-cat="{{item}}"
        >
          <text>{{item}}</text>
          <text wx:if="{{categoryCounts[item]}}" class="menu-rail-count">{{categoryCounts[item]}}</text>
        </view>
      </scroll-view>

      <!-- 右：当前类目大图卡片 -->
      <scroll-view scroll-y class="menu-list" enable-flex>
        <view class="menu-sec">
          <text class="menu-sec-t">{{activeCategory}}</text>
          <view class="menu-sec-line"></view>
        </view>
        <view class="menu-card" wx:for="{{productsByCategory[activeCategory]}}" wx:for-item="p" wx:key="id">
          <view class="menu-card-thumb">
            <image wx:if="{{p.hasImage}}" class="menu-thumb-img" src="{{p.image}}" mode="aspectFill" lazy-load="{{true}}" binderror="onImgError" data-id="{{p.id}}" />
            <view wx:else class="menu-thumb-ph menu-thumb-ph_{{p.ph.glyph}}">{{p.ph.label}}</view>
          </view>
          <view class="menu-card-bd">
            <view class="menu-card-title {{p.status === 2 ? 'menu-soldout' : ''}}">{{p.name}}</view>
            <view class="menu-card-desc">{{p.description || '美味菜品'}}</view>
            <view class="menu-card-bottom">
              <view class="menu-price">¥{{p.hasSpecs ? p.specMinText : p.priceText}}<text wx:if="{{p.hasSpecs}}" class="menu-price-from">起</text></view>
              <view class="menu-action">
                <view wx:if="{{p.status === 2}}" class="menu-soldout">售罄</view>
                <block wx:elif="{{p.hasSpecs}}">
                  <text wx:if="{{cartQtyByProduct[p.id]}}" class="menu-qbadge">{{cartQtyByProduct[p.id]}}</text>
                  <view class="weui-btn weui-btn_mini weui-btn_primary" bindtap="openSpecPicker" data-id="{{p.id}}">选规格</view>
                </block>
                <block wx:else>
                  <view wx:if="{{!cartQtyByKey[p.noSpecKey]}}" class="menu-add-round" bindtap="onAdd" data-id="{{p.id}}">+</view>
                  <view wx:else class="menu-stepper">
                    <view class="menu-step-btn" bindtap="onDec" data-id="{{p.id}}">−</view>
                    <text class="menu-qty">{{cartQtyByKey[p.noSpecKey]}}</text>
                    <view class="menu-step-btn" bindtap="onInc" data-id="{{p.id}}">+</view>
                  </view>
                </block>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

    </view>

    <!-- 购物车结算条（浮动粉药丸：圆形车标 + 价格强调 + 黄色去结算药丸） -->
    <view wx:if="{{cartCount > 0}}" class="menu-cartbar">
      <view class="menu-cart-left" bindtap="openCartSheet">
        <view class="menu-cart-icon">🛒</view>
        <view class="menu-cart-sum">
          <view class="menu-cart-total">¥{{cartTotal}}</view>
          <view class="menu-cart-count">已选 {{cartCount}} 件</view>
        </view>
      </view>
      <view class="menu-cart-go" bindtap="goCart">去结算</view>
    </view>
  </view>

  <!-- 规格选择弹层（商品头 + 规格药丸单选 + 数量步进 + 整宽加入，对齐参考图） -->
  <view wx:if="{{specPickerVisible}}">
    <view class="spec-mask" bindtap="closeSpecPicker"></view>
    <view class="spec-sheet">
      <view class="spec-grab"></view>
      <view class="spec-hd">
        <view class="spec-hd-bd">
          <view class="spec-name">{{specPickerProduct.name}}</view>
          <view class="spec-desc">{{specPickerProduct.description || '美味菜品'}}</view>
        </view>
        <view class="spec-x" bindtap="closeSpecPicker">✕</view>
      </view>

      <view class="spec-group">
        <view class="spec-group-t">规格</view>
        <view class="spec-pills">
          <view
            wx:for="{{specPickerProduct.specs}}" wx:key="id"
            class="spec-pill {{selectedSpecId === item.id ? 'spec-pill_on' : ''}} {{item.status === 2 ? 'spec-pill_off' : ''}}"
            bindtap="selectSpec" data-spec-id="{{item.id}}"
          >{{item.name}} <text class="spec-pill-p">¥{{item.priceText}}</text></view>
        </view>
      </view>

      <view class="spec-bottom">
        <view class="spec-price"><text class="spec-price-cur">¥</text>{{specUnitText}}</view>
        <view class="spec-stepper">
          <view class="menu-step-btn" bindtap="specDec">−</view>
          <text class="menu-qty">{{specQty}}</text>
          <view class="menu-step-btn" bindtap="specInc">＋</view>
        </view>
      </view>

      <button class="weui-btn weui-btn_primary spec-add" disabled="{{!specCanAdd}}" bindtap="confirmAddSpec">加入购物车 · ¥{{specTotalText}}</button>
    </view>
  </view>

  <!-- 购物车弹层（已选商品面板：逐行改量 / 清空 / 去结算） -->
  <view wx:if="{{cartSheetVisible}}">
    <view class="cart-mask" bindtap="closeCartSheet"></view>
    <view class="cart-sheet">
      <view class="cart-hd">
        <view class="cart-hd-t">已选商品</view>
        <view class="cart-clear" bindtap="clearCartAll">🗑 清空</view>
      </view>

      <scroll-view scroll-y class="cart-rows">
        <view class="cart-row" wx:for="{{cartItems}}" wx:key="key">
          <view class="cart-row-thumb">
            <image wx:if="{{item.image}}" class="cart-row-img" src="{{item.image}}" mode="aspectFill" />
            <view wx:else class="cart-row-ph">{{item.name[0]}}</view>
          </view>
          <view class="cart-row-bd">
            <view class="cart-row-name">{{item.name}}</view>
            <view wx:if="{{item.specName}}" class="cart-row-spec">{{item.specName}}</view>
          </view>
          <view class="cart-row-price">¥{{item.lineTotalText}}</view>
          <view class="menu-stepper">
            <view class="menu-step-btn" bindtap="cartDec" data-key="{{item.key}}">−</view>
            <text class="menu-qty">{{item.quantity}}</text>
            <view class="menu-step-btn" bindtap="cartInc" data-key="{{item.key}}">＋</view>
          </view>
        </view>
      </scroll-view>

      <view class="cart-foot">
        <view class="cart-foot-sum">合计 <text class="cart-foot-total">¥{{cartTotal}}</text></view>
        <view class="cart-foot-go" bindtap="goCart">去结算</view>
      </view>
    </view>
  </view>

  <!-- 底部 tabbar -->
  <view class="tabbar-fixed">
    <tabbar current="{{tabbarCurrent}}" bindchange="tabChange" />
  </view>
</view>
