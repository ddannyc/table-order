<!-- pages/menu/index.wxml — 点餐菜单页 -->
<view class="page">

  <!-- 未绑桌 -->
  <view wx:if="{{!boundShopId && !loading}}" class="state-block">
    <view class="state-emoji">📱</view>
    <view class="state-title">未绑定桌号</view>
    <view class="state-desc">请扫描餐桌二维码开始点餐</view>
    <button class="state-btn" bind:tap="scanQR">扫码点餐</button>
    <view class="state-link" bind:tap="goHome">返回首页</view>
  </view>

  <!-- 加载中 -->
  <view wx:elif="{{loading}}" class="state-block">
    <view class="state-desc">加载中…</view>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{error}}" class="state-block">
    <view class="state-emoji">!</view>
    <view class="state-title">加载失败</view>
    <view class="state-desc">网络开小差了，请重试</view>
    <button class="state-btn" bind:tap="onRetry">重新加载</button>
  </view>

  <!-- 空菜单 -->
  <view wx:elif="{{products.length === 0}}" class="state-block">
    <view class="state-emoji">🍽</view>
    <view class="state-title">暂无菜品</view>
    <view class="state-desc">该店铺还没有上架菜品</view>
  </view>

  <!-- 菜单主体 -->
  <view wx:else class="menu-main">

    <!-- 门店栏 + 堂食/外卖切换 -->
    <view class="menu-header">
      <view class="shop-meta">
        <view class="shop-name">{{shop.name || '店铺'}}</view>
        <view class="shop-table">{{orderType === 'delivery' ? '外卖配送' : '桌号 ' + boundTableNo}}</view>
      </view>
      <view class="order-type-toggle">
        <view class="seg {{orderType === 'dine_in' ? 'seg-active' : ''}}" bindtap="switchOrderType" data-type="dine_in">堂食</view>
        <view class="seg {{orderType === 'delivery' ? 'seg-active' : ''}}" bindtap="switchOrderType" data-type="delivery">外卖</view>
      </view>
    </view>

    <!-- 左分类栏 + 右菜品列表 -->
    <view class="menu-body">
      <scroll-view scroll-y class="cat-rail">
        <view
          wx:for="{{categories}}"
          wx:key="this"
          class="cat-item {{activeCategory === item ? 'cat-active' : ''}}"
          bindtap="selectCategory"
          data-cat="{{item}}"
          data-index="{{index}}"
        >{{item}}</view>
      </scroll-view>

      <scroll-view scroll-y class="product-list" scroll-into-view="{{scrollIntoId}}" scroll-with-animation>
        <view wx:for="{{categories}}" wx:key="this" wx:for-item="cat" wx:for-index="ci" id="cat-{{ci}}" class="product-group">
          <view class="group-title">{{cat}}</view>
          <view wx:for="{{productsByCategory[cat]}}" wx:for-item="p" wx:key="id" class="product-row">
            <image wx:if="{{p.image}}" class="product-thumb" src="{{p.image}}" mode="aspectFill" lazy-load="{{true}}" binderror="onImgError" data-id="{{p.id}}" />
            <view wx:else class="product-thumb product-thumb-empty">🍽</view>
            <view class="product-info">
              <view class="product-name {{p.status === 2 ? 'inactive' : ''}}">{{p.name}}</view>
              <view class="product-desc">{{p.description || '美味菜品'}}</view>
              <view class="product-bottom">
                <view class="product-price">
                  <block wx:if="{{p.hasSpecs}}">¥{{p.specMinText}}<text class="price-from">起</text></block>
                  <block wx:else>¥{{p.priceText}}</block>
                </view>
                <view class="product-action">
                  <view wx:if="{{p.status === 2}}" class="sold-out">售罄</view>
                  <block wx:elif="{{p.hasSpecs}}">
                    <view wx:if="{{cartQtyByProduct[p.id]}}" class="spec-qty-badge">{{cartQtyByProduct[p.id]}}</view>
                    <view class="spec-btn" hover-class="btn-press" hover-stay-time="150" bindtap="openSpecPicker" data-id="{{p.id}}">选规格</view>
                  </block>
                  <block wx:else>
                    <view wx:if="{{!cartQtyByKey[p.noSpecKey]}}" class="add-btn" hover-class="btn-press" hover-stay-time="150" bindtap="onAdd" data-id="{{p.id}}">+</view>
                    <view wx:else class="qty-control">
                      <view class="qty-btn" hover-class="btn-press" hover-stay-time="150" bindtap="onDec" data-id="{{p.id}}">−</view>
                      <text class="qty-value">{{cartQtyByKey[p.noSpecKey]}}</text>
                      <view class="qty-btn" hover-class="btn-press" hover-stay-time="150" bindtap="onInc" data-id="{{p.id}}">+</view>
                    </view>
                  </block>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="list-foot-pad"></view>
      </scroll-view>
    </view>

    <!-- 购物车结算条 -->
    <view wx:if="{{cartCount > 0}}" class="cart-bar" bindtap="goCart">
      <view class="cart-info">
        <view class="cart-icon">🛒</view>
        <view class="cart-count">{{cartCount}} 件</view>
        <view class="cart-total">¥{{cartTotal}}</view>
      </view>
      <view class="cart-btn">去结算</view>
    </view>
  </view>

  <!-- 规格选择层 -->
  <view wx:if="{{specPickerVisible}}" class="spec-mask" bindtap="closeSpecPicker">
    <view class="spec-sheet" catchtap="noop">
      <view class="spec-sheet-hd">
        <text class="spec-sheet-title">{{specPickerProduct.name}}</text>
        <text class="spec-close" bindtap="closeSpecPicker">✕</text>
      </view>
      <view class="spec-list">
        <view wx:for="{{specPickerProduct.specs}}" wx:key="id" class="spec-opt">
          <view class="spec-opt-info">
            <text class="spec-opt-name">{{item.name}}</text>
            <text class="spec-opt-price">¥{{item.priceText}}</text>
          </view>
          <view wx:if="{{item.status === 2}}" class="sold-out">售罄</view>
          <view wx:else class="spec-add-btn" hover-class="btn-press" hover-stay-time="150" bindtap="pickSpec" data-spec-id="{{item.id}}">加入</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部 tabbar -->
  <custom-tab-bar current="{{tabbar.current}}" bindchange="tabChange" list="{{tabbar.list}}" />
</view>
