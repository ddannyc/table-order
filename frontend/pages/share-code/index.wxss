/* pages/share-code/index.wxss */
.page {
  padding-bottom: 40rpx;
}

.header {
  background: var(--weui-BRAND);
  padding: 80rpx var(--space-lg) var(--space-xl);
  text-align: center;
  color: #fff;
  margin-bottom: var(--space-md);
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.header-sub {
  font-size: var(--font-body);
  opacity: 0.85;
}

.qr-section {
  text-align: center;
  padding: var(--space-xl);
  margin-bottom: var(--space-md);
}

.qr-image-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.qr-image {
  width: 300rpx;
  height: 300rpx;
}

.qr-placeholder {
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-md);
  background: var(--weui-BG-1);
  color: var(--weui-FG-2);
  font-size: var(--font-body);
}

.qr-tip {
  font-size: 26rpx;
  color: var(--weui-FG-2);
}

.reward-info {
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
}

.info-label {
  font-size: var(--font-body);
  color: var(--weui-FG-1);
}

.info-value {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
  font-weight: 500;
}

.info-value.gold {
  color: var(--weui-BRAND);
  font-size: var(--font-title);
  font-weight: bold;
}

.rates-card {
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.rates-title {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--weui-FG-0);
  margin-bottom: var(--space-md);
}

.rate-item {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-sm) 0;
  border-bottom: 2rpx solid var(--weui-BG-1);
}

.rate-item:last-child {
  border-bottom: none;
}

.rate-pct {
  width: 80rpx;
  height: 48rpx;
  background: var(--weui-BG-2);
  color: var(--weui-BRAND);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-body);
  font-weight: bold;
  flex-shrink: 0;
}

.rate-pct.primary {
  background: var(--weui-BG-2);
  color: var(--weui-BRAND);
}

.rate-desc {
  font-size: 26rpx;
  color: var(--weui-FG-1);
}

.paused-bar {
  background: var(--weui-BG-1);
  color: var(--weui-FG-1);
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-md);
}

.actions {
  padding: 0 var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

/* 登录提示卡片 */
.login-prompt-card {
  text-align: center;
  padding: 80rpx 48rpx;
  margin: 40rpx 32rpx;
}

.prompt-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  background: var(--weui-BG-2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  font-size: 64rpx;
}

.prompt-title {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--weui-FG-0);
  margin-bottom: 12rpx;
}

.prompt-desc {
  font-size: var(--font-body);
  color: var(--weui-FG-2);
  margin-bottom: var(--space-xl);
}
