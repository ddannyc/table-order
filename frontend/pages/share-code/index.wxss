/* pages/share-code/index.wxss */
.page {
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 32rpx 48rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.header-sub {
  font-size: 28rpx;
  opacity: 0.85;
}

.qr-section {
  text-align: center;
  padding: 48rpx;
  margin-bottom: 24rpx;
}

.qr-image-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.qr-image {
  width: 300rpx;
  height: 300rpx;
}

.qr-placeholder {
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  background: #f5f5f5;
  color: #999;
  font-size: 28rpx;
}

.qr-tip {
  font-size: 26rpx;
  color: #999;
}

.reward-info {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.gold {
  color: #FFD700;
  font-size: 36rpx;
  font-weight: bold;
}

.rates-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.rates-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.rate-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.rate-item:last-child {
  border-bottom: none;
}

.rate-pct {
  width: 80rpx;
  height: 48rpx;
  background: #e8f5e9;
  color: #2e7d32;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.rate-pct.primary {
  background: #e3f2fd;
  color: #1565c0;
}

.rate-desc {
  font-size: 26rpx;
  color: #666;
}

.paused-bar {
  background: #fff3cd;
  color: #856404;
  padding: 20rpx 32rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.actions {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
