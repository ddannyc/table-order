/* pages/share-code/index.wxss */
.page {
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #07c160 0%, #059a4c 100%);
  padding: 80rpx var(--space-lg) var(--space-xl);
  text-align: center;
  color: var(--color-bg-surface);
  margin-bottom: var(--space-md);
}

.header-title {
  font-size: var(--font-h1);
  font-weight: bold;
  margin-bottom: 12rpx;
}

.header-sub {
  font-size: var(--font-body);
  opacity: 0.85;
}

.qr-section {
  text-align: center;
  padding: var(--space-xl);
  margin-bottom: var(--space-md);
}

.qr-image-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.qr-image {
  width: 300rpx;
  height: 300rpx;
}

.qr-placeholder {
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-md);
  background: var(--color-bg-page);
  color: var(--color-text-hint);
  font-size: var(--font-body);
}

.qr-tip {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
}

.reward-info {
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
}

.info-label {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
}

.info-value {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  font-weight: 500;
}

.info-value.gold {
  color: var(--color-gold);
  font-size: var(--font-title);
  font-weight: bold;
}

.rates-card {
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.rates-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-md);
}

.rate-item {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-sm) 0;
  border-bottom: 2rpx solid var(--color-bg-page);
}

.rate-item:last-child {
  border-bottom: none;
}

.rate-pct {
  width: 80rpx;
  height: 48rpx;
  background: #e8f5e9;
  color: #2e7d32;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-body);
  font-weight: bold;
  flex-shrink: 0;
}

.rate-pct.primary {
  background: #e3f2fd;
  color: #1565c0;
}

.rate-desc {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.paused-bar {
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-md);
}

.actions {
  padding: 0 var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}
