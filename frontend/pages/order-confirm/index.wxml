<!-- pages/order-confirm/index.wxml -->
<view class="page">
  <!-- 店铺信息 -->
  <view class="shop-card card">
    <view class="shop-head">
      <view class="shop-name">{{shop.name || '店铺'}}</view>
      <view class="order-type-tag">{{orderTypeLabel}}</view>
    </view>
    <view wx:if="{{orderType !== 'delivery'}}" class="table-no">桌号: {{tableNo}}</view>
  </view>

  <!-- 订单商品列表 -->
  <view class="order-items card">
    <view class="section-title">订单明细</view>
    <mp-cells>
      <view wx:for="{{cartItems}}" wx:key="id">
        <mp-cell>
          <view slot="title" class="order-item-cell">
            <text class="item-name">{{item.name}}</text>
            <text class="item-qty">x{{item.quantity}}</text>
          </view>
          <view slot="footer" class="item-price">¥{{item.subtotal}}</view>
        </mp-cell>
      </view>
    </mp-cells>
  </view>

  <!-- 金额卡片 -->
  <view class="card amount-card">
    <mp-cells>
      <mp-cell>
        <view slot="title">商品金额</view>
        <view slot="footer" class="value-text">¥{{totalAmount}}</view>
      </mp-cell>
      <mp-cell wx:if="{{useReward}}">
        <view slot="title" class="text-primary">福利金抵扣</view>
        <view slot="footer" class="text-discount">-¥{{rewardDeduct}}</view>
      </mp-cell>
      <mp-cell>
        <view slot="title" class="total-label">{{useReward ? '应付金额' : '合计'}}</view>
        <view slot="footer" class="total-amount text-primary">¥{{actualPayAmount}}</view>
      </mp-cell>
    </mp-cells>
  </view>

  <!-- 福利金开关（需要登录） -->
  <view wx:if="{{!needLogin && rewardBalance > 0}}" class="reward-card card">
    <view class="reward-toggle" bind:tap="toggleUseReward">
      <view class="toggle-left">
        <view class="toggle-title">使用福利金抵扣</view>
        <view class="toggle-desc">可用 ¥{{rewardBalance}} (最高抵扣 {{rewardCeiling}}%)</view>
      </view>
      <view class="toggle-switch {{useReward ? 'on' : ''}}"></view>
    </view>
  </view>

  <!-- 福利金余额（需要登录） -->
  <view wx:if="{{!needLogin}}" class="card reward-amount-card">
    <view class="section-title">福利金</view>
    <mp-cells>
      <mp-cell>
        <view slot="title">可用福利金</view>
        <view slot="footer" class="value-gold">¥{{rewardBalance}}</view>
      </mp-cell>
    </mp-cells>
  </view>

  <!-- 底部提交栏 -->
  <view class="submit-bar">
    <view class="submit-info">
      <text class="submit-label">{{useReward ? '应付' : '合计'}}</text>
      <text class="submit-amount">¥{{actualPayAmount}}</text>
    </view>
    <button wx:if="{{!needLogin}}" class="weui-btn" type="primary" bindtap="handlePay" loading="{{loading}}">
      确认支付
    </button>
    <button wx:else class="weui-btn" type="primary" bindtap="handleLogin">
      登录后下单
    </button>
  </view>
</view>