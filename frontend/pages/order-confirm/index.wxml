<!-- pages/order-confirm/index.wxml -->
<view class="page">
  <!-- 店铺信息 -->
  <view class="shop-card card">
    <view class="shop-head">
      <view class="shop-name">{{shop.name || '店铺'}}</view>
      <view class="order-type-tag">{{orderTypeLabel}}</view>
    </view>
    <view wx:if="{{orderType !== 'delivery'}}" class="table-no">桌号: {{tableNo}}</view>
    <view wx:elif="{{deliveryAddress}}" class="delivery-addr" bindtap="chooseDeliveryAddress">
      <view class="addr-line">{{deliveryAddress.userName}} {{deliveryAddress.telNumber}}</view>
      <view class="addr-detail">{{deliveryAddress.provinceName}}{{deliveryAddress.cityName}}{{deliveryAddress.countyName}}{{deliveryAddress.detailInfo}}</view>
      <view class="addr-change">点击更换地址 ›</view>
    </view>
    <view wx:else class="delivery-addr-empty" bindtap="chooseDeliveryAddress">+ 选择收货地址</view>
  </view>

  <!-- 订单商品列表（照片缩略图，照搬参考图） -->
  <view class="order-items card">
    <view class="section-title">订单明细</view>
    <view class="oc-item" wx:for="{{cartItems}}" wx:key="key">
      <image wx:if="{{item.image}}" class="oc-item-thumb" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}" />
      <view wx:else class="oc-item-thumb oc-item-thumb_ph"></view>
      <view class="oc-item-bd">
        <view class="oc-item-name">{{item.name}}{{item.specName ? ' · ' + item.specName : ''}}</view>
        <view class="oc-item-qty">x{{item.quantity}}</view>
      </view>
      <view class="oc-item-price">¥{{item.subtotal}}</view>
    </view>
  </view>

  <!-- 金额卡片 -->
  <view class="card amount-card">
    <mp-cells>
      <mp-cell>
        <view slot="title">商品金额</view>
        <view slot="footer" class="value-text">¥{{totalAmount}}</view>
      </mp-cell>
      <mp-cell wx:if="{{orderType === 'delivery'}}">
        <view slot="title">配送费</view>
        <view slot="footer" class="value-text">¥{{deliveryFee}}</view>
      </mp-cell>
      <mp-cell wx:if="{{useReward}}">
        <view slot="title" class="text-primary">福利金抵扣</view>
        <view slot="footer" class="text-discount">-¥{{rewardDeduct}}</view>
      </mp-cell>
      <mp-cell>
        <view slot="title" class="total-label">{{useReward ? '应付金额' : '合计'}}</view>
        <view slot="footer" class="total-amount">¥{{actualPayAmount}}</view>
      </mp-cell>
    </mp-cells>
  </view>

  <!-- 福利金抵扣开关（仅优惠抵扣，非支付方式；需要登录且有余额） -->
  <view wx:if="{{!needLogin && rewardBalance > 0}}" class="reward-card card">
    <view class="reward-toggle">
      <view class="toggle-left">
        <view class="toggle-title">使用福利金抵扣</view>
        <view class="toggle-desc">可用 ¥{{rewardBalance}} · 最高抵扣 {{rewardCeiling}}%</view>
      </view>
      <switch checked="{{useReward}}" color="#FF4896" bindchange="toggleUseReward" />
    </view>
  </view>

  <!-- 支付方式：仅微信支付（后端订单仅支持微信 + 福利金抵扣） -->
  <view class="card pay-card">
    <view class="section-title">支付方式</view>
    <view class="pay-method">
      <view class="wx-badge">微</view>
      <text class="pay-name">微信支付</text>
      <text class="pay-check">✓</text>
    </view>
  </view>

  <!-- 底部提交栏 -->
  <view class="submit-bar">
    <view class="submit-info">
      <text class="submit-label">{{useReward ? '应付' : '合计'}}</text>
      <text class="submit-amount">¥{{actualPayAmount}}</text>
    </view>
    <button wx:if="{{!needLogin}}" class="weui-btn" type="primary" bindtap="handlePay" loading="{{loading}}">
      确认支付
    </button>
    <button wx:else class="weui-btn" type="primary" bindtap="handleLogin">
      登录后下单
    </button>
  </view>
</view>