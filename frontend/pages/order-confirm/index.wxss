/* pages/order-confirm/index.wxss */
.shop-card {
  text-align: center;
  padding: 40rpx var(--space-lg);
}

.shop-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
}

.order-type-tag {
  background: var(--weui-BRAND);
  color: #fff;
  font-size: var(--font-caption);
  padding: 2rpx 16rpx;
  border-radius: var(--radius-lg);
}

.delivery-addr {
  margin-top: var(--space-sm);
  text-align: left;
}

.addr-change {
  margin-top: 8rpx;
  font-size: var(--font-caption);
  color: var(--weui-BRAND);
}

.delivery-addr-empty {
  padding: 32rpx var(--space-lg);
  text-align: center;
  color: var(--weui-BRAND);
  font-size: var(--font-body);
}

.addr-line {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}

.addr-detail {
  margin-top: 4rpx;
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
}

.section-title {
  font-size: var(--font-body);
  font-weight: 800;
  color: var(--jf-title-blue);
  padding: var(--space-sm) 0;
  display: flex;
  align-items: baseline;
}

.section-title::before {
  content: "#";
  color: var(--weui-BRAND);
  font-weight: 800;
  margin-right: 6rpx;
}

/* 明细行：缩略图 + 名称/规格 + 数量 + 陶土橙小计（照搬参考图） */
.oc-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--weui-FG-3);
}
.oc-item:last-child {
  border-bottom: none;
}
.oc-item-thumb {
  flex: none;
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  background: #FBE9F0; /* 浅粉暖底，空图也不显空 */
}
.oc-item-thumb_ph {
  border: 1rpx solid var(--weui-FG-3);
}
.oc-item-bd {
  flex: 1;
  min-width: 0;
}
.oc-item-name {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}
.oc-item-qty {
  margin-top: 4rpx;
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}
.oc-item-price {
  flex: none;
  font-size: var(--font-price);
  font-weight: 600;
  color: var(--price-ink);
}

.amount-card {
  margin-bottom: var(--space-md);
}

.value-text {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
  font-weight: 500;
}

.text-discount { color: var(--weui-BRAND); }

.total-label {
  font-weight: 600;
  color: var(--weui-FG-0);
  font-size: var(--font-body);
}

.total-amount {
  font-size: var(--font-title);
  font-weight: bold;
}

.reward-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
}

.toggle-left { flex: 1; }
.toggle-title { font-size: var(--font-body); font-weight: 500; color: var(--weui-FG-0); }
.toggle-desc { font-size: var(--font-caption); color: var(--weui-FG-2); margin-top: var(--space-xs); }

/* 支付方式：仅微信支付（绿徽 + 选中勾） */
.pay-card { margin-bottom: var(--space-md); }
.pay-method {
  display: flex;
  align-items: center;
  padding: var(--space-sm) 0;
}
.wx-badge {
  flex: none;
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: #1AAD19; /* 微信品牌绿 */
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-sm);
}
.pay-name { flex: 1; font-size: var(--font-body); color: var(--weui-FG-0); }
.pay-check { color: var(--weui-BRAND); font-weight: 700; font-size: 32rpx; }

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-info {
  display: flex;
  align-items: baseline;
  gap: var(--space-xs);
}

.submit-label {
  font-size: var(--font-body);
  color: var(--weui-FG-2);
}

.submit-amount {
  font-size: var(--font-price-large);
  font-weight: bold;
  color: var(--price-ink); /* 陶土橙大额，照搬参考图底部总价 */
}
