/* pages/order-confirm/index.wxss */
.shop-card {
  text-align: center;
  padding: 40rpx var(--space-lg);
}

.shop-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
}

.order-type-tag {
  background: var(--brand-accent);
  color: var(--color-text-on-brand);
  font-size: var(--font-caption);
  padding: 2rpx 16rpx;
  border-radius: var(--radius-lg);
}

.section-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text-primary);
  padding: var(--space-sm) 0;
}

.order-item-cell {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.item-name {
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

.item-qty {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
  background: var(--color-bg-page);
  padding: 4rpx var(--space-sm);
  border-radius: 20rpx;
}

.item-price {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
}

.amount-card {
  margin-bottom: var(--space-md);
}

.value-text {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  font-weight: 500;
}

.text-discount { color: var(--weui-primary); }

.total-label {
  font-weight: 600;
  color: var(--color-text-primary);
  font-size: var(--font-body);
}

.total-amount {
  font-size: var(--font-title);
  font-weight: bold;
}

.reward-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
}

.toggle-left { flex: 1; }
.toggle-title { font-size: var(--font-body); font-weight: 500; color: var(--color-text-primary); }
.toggle-desc { font-size: var(--font-caption); color: var(--color-text-hint); margin-top: var(--space-xs); }

.toggle-switch {
  width: 104rpx;
  height: 56rpx;
  background: var(--color-text-disabled);
  border-radius: 28rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-switch.on {
  background: var(--weui-primary);
}

.toggle-switch::after {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  background: var(--color-bg-surface);
  border-radius: 50%;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.3s;
}

.toggle-switch.on::after {
  left: 52rpx;
}

.reward-amount-card { margin-bottom: var(--space-md); }
.value-gold { font-size: var(--font-body); color: var(--color-gold); font-weight: 500; }

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-surface);
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-info {
  display: flex;
  align-items: baseline;
  gap: var(--space-xs);
}

.submit-label {
  font-size: var(--font-body);
  color: var(--color-text-hint);
}

.submit-amount {
  font-size: var(--font-price-large);
  font-weight: bold;
  color: var(--weui-primary);
}