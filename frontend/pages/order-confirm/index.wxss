/* pages/order-confirm/index.wxss */
.shop-card {
  text-align: center;
  padding: 40rpx var(--space-lg);
}

.shop-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
}

.order-type-tag {
  background: var(--weui-BRAND);
  color: #fff;
  font-size: var(--font-caption);
  padding: 2rpx 16rpx;
  border-radius: var(--radius-lg);
}

.delivery-addr {
  margin-top: var(--space-sm);
  text-align: left;
}

.addr-line {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}

.addr-detail {
  margin-top: 4rpx;
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
}

.section-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--weui-FG-0);
  padding: var(--space-sm) 0;
}

.order-item-cell {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.item-name {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
}

.item-qty {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
  background: var(--weui-BG-1);
  padding: 4rpx var(--space-sm);
  border-radius: 20rpx;
}

.item-price {
  font-size: var(--font-body);
  color: var(--weui-FG-1);
}

.amount-card {
  margin-bottom: var(--space-md);
}

.value-text {
  font-size: var(--font-body);
  color: var(--weui-FG-0);
  font-weight: 500;
}

.text-discount { color: var(--weui-BRAND); }

.total-label {
  font-weight: 600;
  color: var(--weui-FG-0);
  font-size: var(--font-body);
}

.total-amount {
  font-size: var(--font-title);
  font-weight: bold;
}

.reward-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
}

.toggle-left { flex: 1; }
.toggle-title { font-size: var(--font-body); font-weight: 500; color: var(--weui-FG-0); }
.toggle-desc { font-size: var(--font-caption); color: var(--weui-FG-2); margin-top: var(--space-xs); }

.reward-amount-card { margin-bottom: var(--space-md); }
.value-gold { font-size: var(--font-body); color: var(--weui-FG-0); font-weight: 500; }

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-info {
  display: flex;
  align-items: baseline;
  gap: var(--space-xs);
}

.submit-label {
  font-size: var(--font-body);
  color: var(--weui-FG-2);
}

.submit-amount {
  font-size: var(--font-price-large);
  font-weight: bold;
  color: var(--weui-BRAND);
}
