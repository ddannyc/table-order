/* pages/order-confirm/index.wxss */
.shop-card {
  text-align: center;
  padding: 40rpx 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 16rpx 0;
}

.order-item-cell {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-qty {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.item-price {
  font-size: 28rpx;
  color: #666;
}

.amount-card {
  margin-bottom: 24rpx;
}

.value-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.text-discount { color: var(--weui-primary); }

.total-label {
  font-weight: 600;
  color: #333;
  font-size: 28rpx;
}

.total-amount {
  font-size: 36rpx;
  font-weight: bold;
}

.reward-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
}

.toggle-left { flex: 1; }
.toggle-title { font-size: 28rpx; font-weight: 500; color: #333; }
.toggle-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.toggle-switch {
  width: 104rpx;
  height: 56rpx;
  background: #ccc;
  border-radius: 28rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-switch.on {
  background: var(--weui-primary);
}

.toggle-switch::after {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.3s;
}

.toggle-switch.on::after {
  left: 52rpx;
}

.reward-amount-card { margin-bottom: 24rpx; }
.value-gold { font-size: 28rpx; color: #FFD700; font-weight: 500; }

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.submit-label {
  font-size: 28rpx;
  color: #999;
}

.submit-amount {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--weui-primary);
}