<!-- pages/login/index.wxml -->
<view class="page login-page">
  <view class="login-logo">
    <text class="logo-icon">🍽</text>
  </view>
  <view class="login-info">
    <view class="app-name">餐饮点餐</view>
    <view class="app-desc">扫码点餐 · 福利会员 · 邀请返利</view>
  </view>
  <view class="login-btn-wrap">
    <button class="weui-btn weui-btn_primary" bindtap="handleLogin" loading="{{loading}}">
      微信授权登录
    </button>
  </view>
</view>