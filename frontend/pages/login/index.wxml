<!-- pages/login/index.wxml -->
<view class="page login-page">
  <view class="login-brand-area">
    <view class="login-logo">
      <text class="logo-icon">🍽</text>
    </view>
    <view class="login-info">
      <view class="app-name">鸡福旺</view>
      <view class="app-desc">扫码点餐 · 福利会员 · 邀请返利</view>
    </view>
  </view>

  <view class="weui-cells weui-cells_after-title login-features">
    <view class="weui-cell">
      <view class="weui-cell__hd"><i class="weui-icon-success-circle"></i></view>
      <view class="weui-cell__bd">扫码即点，无需排队</view>
    </view>
    <view class="weui-cell">
      <view class="weui-cell__hd"><i class="weui-icon-success-circle"></i></view>
      <view class="weui-cell__bd">邀请好友，赚取福利金</view>
    </view>
    <view class="weui-cell">
      <view class="weui-cell__hd"><i class="weui-icon-success-circle"></i></view>
      <view class="weui-cell__bd">消费返利，最高 13%</view>
    </view>
  </view>

  <view class="login-btn-wrap">
    <button class="weui-btn" type="primary" bindtap="handleLogin" loading="{{loading}}">
      微信授权登录
    </button>
  </view>
</view>
