/* pages/login/index.wxss */
.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0faf4 0%, #fff 40%);
  padding: 80rpx 0;
}

.login-brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  background: var(--weui-primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-xl);
  font-size: 80rpx;
}

.login-info {
  text-align: center;
}

.app-name {
  font-size: var(--font-h1);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}

.app-desc {
  font-size: var(--font-body);
  color: var(--color-text-hint);
}

.login-features {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-bottom: 80rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.feature-icon {
  width: 40rpx;
  height: 40rpx;
  background: var(--weui-primary);
  color: var(--color-bg-surface);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.feature-text {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
}

.login-btn-wrap {
  width: 600rpx;
}