/* pages/login/index.wxss */
.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--weui-BG-0);
  padding: 80rpx 0;
}

.login-brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  background: var(--weui-BG-2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-xl);
  font-size: 80rpx;
}

.login-info {
  text-align: center;
}

.app-name {
  font-size: var(--font-h1);
  font-weight: bold;
  color: var(--weui-FG-0);
  margin-bottom: var(--space-sm);
}

.app-desc {
  font-size: var(--font-body);
  color: var(--weui-FG-2);
}

.login-features {
  width: 600rpx;
  margin-bottom: 80rpx;
}

.login-btn-wrap {
  width: 600rpx;
}
