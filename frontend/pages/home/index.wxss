/* pages/home/index.wxss — 选餐入口启动页 */
.home-hd {
  padding: 60rpx var(--space-lg) 40rpx;
}

.home-title {
  font-size: var(--font-h1);
  font-weight: 600;
  color: var(--weui-FG-0);
}

.home-sub {
  margin-top: var(--space-xs);
  font-size: var(--font-body);
  color: var(--weui-FG-2);
}

.home-emoji {
  font-size: 56rpx;
  margin-right: var(--space-md);
}

.home-entry-name {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--weui-FG-0);
}

.home-entry-desc {
  margin-top: 4rpx;
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.home-badge {
  margin-left: var(--space-xs);
  font-size: var(--font-caption);
  color: var(--weui-BRAND);
}
