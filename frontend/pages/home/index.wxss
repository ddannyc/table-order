/* pages/home/index.wxss — 选餐入口启动页 */
.home-page {
  display: flex;
  flex-direction: column;
}

.home-hd {
  padding: 48rpx var(--space-lg) 32rpx;
}

.home-title {
  font-size: var(--font-h1);
  font-weight: 600;
  color: var(--weui-FG-0);
}

.home-sub {
  margin-top: var(--space-xs);
  font-size: var(--font-body);
  color: var(--weui-FG-2);
}

/* 两个大入口卡，纵向居中填充剩余空间 */
.home-entries {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-lg);
  padding: 0 var(--space-lg) 200rpx;
}

.entry-card {
  position: relative;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 64rpx var(--space-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.entry-card_tap {
  opacity: 0.85;
}

.entry-emoji {
  font-size: 104rpx;
  line-height: 1;
}

.entry-name {
  font-size: var(--font-h2);
  font-weight: 600;
  color: var(--weui-FG-0);
}

.entry-desc {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}
