/* pages/home/index.wxss — 选餐入口启动页 */
.home-page {
  display: flex;
  flex-direction: column;
}

/* 品牌 band：深松绿压场，奶油字标 + 引导（8.4:1） */
.home-brandband {
  background: var(--weui-BRAND);
  padding: 64rpx var(--space-lg) 40rpx;
  padding-top: calc(64rpx + env(safe-area-inset-top));
}

.home-title {
  font-size: var(--font-h1);
  font-weight: 600;
  letter-spacing: 2rpx; /* 字标处理：收紧字距，不靠异体字体（小程序限制） */
  color: var(--weui-BG-0);
}

.home-sub {
  margin-top: var(--space-xs);
  font-size: var(--font-body);
  color: var(--weui-BG-2); /* 浅奶油，弱于字标但仍清晰 */
  opacity: 0.85;
}

/* signature：单线蒸笼 hero。金描边写死于 SVG（data-URI 无法引 CSS 变量），
   与 --brand-accent #C98A2B 同源；改色须两处同步。真机渲染需 C1 核对。 */
.home-hero {
  height: 220rpx;
  margin: var(--space-lg) var(--space-lg) 0;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%20240%20120'%20fill%3D'none'%20stroke%3D'%23C98A2B'%20stroke-width%3D'3'%20stroke-linecap%3D'round'%20stroke-linejoin%3D'round'%3E%3Cpath%20d%3D'M98%2028q-7-9%200-18M120%2024q-7-9%200-18M142%2028q7-9%200-18'%2F%3E%3Cellipse%20cx%3D'120'%20cy%3D'50'%20rx%3D'50'%20ry%3D'12'%2F%3E%3Cpath%20d%3D'M72%2050v28q0%208%2048%208t48-8V50'%2F%3E%3Cpath%20d%3D'M76%2068q44%2010%2088%200'%2F%3E%3Cpath%20d%3D'M150%2094q24%2020%2046%200'%2F%3E%3Cpath%20d%3D'M194%2070l18-14M199%2074l18-14'%2F%3E%3C%2Fsvg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

/* 两个大入口卡，纵向居中填充剩余空间 */
.home-entries {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-lg);
  padding: 0 var(--space-lg) 200rpx;
}

.entry-card {
  position: relative;
  background: var(--weui-BG-1);
  border: 1rpx solid var(--brand-accent); /* 金发丝线 */
  border-radius: var(--radius-lg);
  padding: 64rpx var(--space-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
  box-shadow: 0 2rpx 12rpx rgba(44, 74, 59, 0.06); /* 暖绿向阴影 */
}

.entry-card_tap {
  opacity: 0.85;
}

.entry-emoji {
  font-size: 104rpx;
  line-height: 1;
}

.entry-name {
  font-size: var(--font-h2);
  font-weight: 600;
  color: var(--weui-BRAND); /* 深绿标题 */
}

.entry-desc {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}
