/* pages/home/index.wxss — 选餐入口（v6 设计稿）。插画背景类见 home-art.wxss。 */
@import './home-art.wxss';

.home-page {
  display: flex;
  flex-direction: column;
}

/* 品牌头：深松绿渐变，圆角下沿 */
.home-hd {
  background: linear-gradient(160deg, var(--weui-BRAND), var(--green-2));
  padding: 24rpx 36rpx 48rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  border-radius: 0 0 40rpx 40rpx;
}

.brandrow {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.logo {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: #fff;
  color: var(--weui-BRAND);
  font-size: 38rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.15);
}

.brandname {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: #fff;
}

.brandsub {
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

/* 堂食/外卖分段 */
.seg {
  display: flex;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 26rpx;
  padding: 8rpx;
  margin-top: 36rpx;
}

.seg .s {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}

.seg .s_on {
  background: #fff;
  color: var(--weui-BRAND);
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.seg_tap {
  opacity: 0.85;
}

/* 扫码点餐卡（上提压住品牌头下沿） */
.scan {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--weui-BG-1);
  border-radius: 28rpx;
  padding: 28rpx;
  margin: -28rpx 36rpx 0;
  box-shadow: 0 10rpx 36rpx rgba(214, 26, 96, 0.08);
}

.scan-qr {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background-color: var(--weui-BRAND);
  background-repeat: no-repeat;
  background-position: center;
  background-size: 42rpx 42rpx;
}

.scan-t {
  font-size: 30rpx;
  color: var(--weui-FG-0);
  font-weight: 600;
}

.scan-d {
  font-size: 23rpx;
  color: var(--weui-FG-2);
  margin-top: 6rpx;
}

.scan-go {
  margin-left: auto;
  color: var(--weui-BRAND);
  font-size: 40rpx;
}

.scan_tap {
  opacity: 0.9;
}

/* 现炸 banner */
.banner {
  position: relative;
  margin: 32rpx 36rpx 0;
  height: 300rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: linear-gradient(120deg, var(--jf-orange), var(--weui-BRAND));
  display: flex;
  align-items: center;
  padding: 0 36rpx;
}

.banner-txt {
  position: relative;
  z-index: 2;
}

.banner-h {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.18);
}

.banner-p {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  margin-top: 8rpx;
}

.banner-b {
  display: inline-block;
  margin-top: 20rpx;
  background: var(--accent);
  color: var(--jf-title-blue);
  font-size: 24rpx;
  font-weight: 800;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
}

.home-hero {
  position: absolute;
  right: 12rpx;
  bottom: 0;
  width: 300rpx;
  height: 296rpx;
  background-repeat: no-repeat;
  background-position: right bottom;
  background-size: contain;
}

/* 人气推荐 */
.sec-title {
  display: flex;
  align-items: center;
  padding: 44rpx 36rpx 20rpx;
}

.sec-h {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--jf-title-blue);
  display: flex;
  align-items: baseline;
}

.sec-h::before {
  content: "#";
  color: var(--weui-BRAND);
  font-weight: 800;
  margin-right: 6rpx;
}

.sec-more {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--weui-FG-2);
}

.promos {
  display: flex;
  gap: 26rpx;
  padding: 4rpx 36rpx 200rpx;
}

.promo {
  flex: 1;
  background: var(--weui-BG-1);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 36rpx rgba(214, 26, 96, 0.06);
}

.promo-img {
  height: 208rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 70% 70%;
}

.warm1 { background: radial-gradient(circle at 40% 35%, #FFE6B0, #F6B450); }
.warm2 { background: radial-gradient(circle at 40% 35%, #FFEFC2, #FFC94D); }

.promo-ct {
  padding: 22rpx 26rpx;
}

.promo-n {
  font-size: 28rpx;
  color: var(--weui-FG-0);
}

.promo-pr {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--price-ink);
  font-family: var(--font-number);
}

.promo-from {
  font-size: 21rpx;
  font-weight: 400;
  color: var(--weui-FG-2);
  margin-left: 2rpx;
}
