/* pages/home/index.wxss */
.scan-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 80rpx 40rpx;
}

.prompt-icon {
  width: 192rpx;
  height: 192rpx;
  background: var(--weui-primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  font-size: 96rpx;
}

.prompt-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.prompt-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
  text-align: center;
}

.category-section {
  margin-bottom: 8rpx;
}

.product-row {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-name.inactive {
  color: #ccc;
  text-decoration: line-through;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.product-price {
  font-size: 34rpx;
  color: var(--weui-primary);
  font-weight: bold;
  margin-top: 8rpx;
}

.product-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: var(--weui-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3); /* custom shadow, --weui-primary-light is too light */
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  background: #fff;
  border: 2rpx solid var(--weui-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--weui-primary);
}

.qty-value {
  font-size: 32rpx;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
  color: #333;
}

.sold-out {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* cart-bar 在 form-page button slot 中，不需要 fixed 定位 */
.cart-bar {
  background: var(--weui-primary);
  color: #fff;
  padding: 28rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-info {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.cart-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-count {
  font-size: 28rpx;
}

.cart-total {
  font-size: 40rpx;
  font-weight: bold;
}

.cart-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* header title with change-table button */
.header-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.change-table-btn {
  font-size: 24rpx;
  color: var(--weui-primary);
  background: var(--weui-primary-light);
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  margin-left: 16rpx;
}