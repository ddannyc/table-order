<!-- pages/home/index.wxml — 选餐入口启动页 -->
<view class="page launcher">

  <view class="hero">
    <view class="hero-title">欢迎光临</view>
    <view class="hero-sub">请选择您的点餐方式</view>
  </view>

  <view class="entry-cards">
    <view class="entry-card dine-in" hover-class="entry-press" hover-stay-time="120" bindtap="scanDineIn">
      <view class="entry-emoji">🍽️</view>
      <view class="entry-name">堂食</view>
      <view class="entry-desc">扫码点餐 · 桌边享用</view>
    </view>

    <view class="entry-card delivery" hover-class="entry-press" hover-stay-time="120" bindtap="chooseDelivery">
      <view class="entry-badge">即将上线</view>
      <view class="entry-emoji">🛵</view>
      <view class="entry-name">外卖</view>
      <view class="entry-desc">送货上门 · 在家品尝</view>
    </view>
  </view>

  <!-- 底部 tabbar -->
  <mp-tabbar list="{{tabbarList}}" current="{{tabbarCurrent}}" bindchange="tabChange" />
</view>
