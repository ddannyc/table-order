<!-- pages/home/index.wxml — 选餐入口启动页 -->
<view class="page home-page">

  <view class="home-hd">
    <view class="home-title">欢迎光临</view>
    <view class="home-sub">请选择您的点餐方式</view>
  </view>

  <view class="home-entries">
    <view class="entry-card" hover-class="entry-card_tap" hover-stay-time="120" bindtap="scanDineIn">
      <view class="entry-emoji">🍽️</view>
      <view class="entry-name">堂食</view>
      <view class="entry-desc">扫码点餐 · 桌边享用</view>
    </view>

    <view class="entry-card" hover-class="entry-card_tap" hover-stay-time="120" bindtap="chooseDelivery">
      <view class="entry-emoji">🛵</view>
      <view class="entry-name">外卖</view>
      <view class="entry-desc">送货上门 · 在家品尝</view>
    </view>
  </view>

  <!-- 底部 tabbar -->
  <view class="tabbar-fixed">
    <mp-tabbar list="{{tabbarList}}" current="{{tabbarCurrent}}" bindchange="tabChange" />
  </view>
</view>
