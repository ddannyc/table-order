<!-- pages/home/index.wxml — 选餐入口启动页 -->
<view class="page">

  <view class="home-hd">
    <view class="home-title">欢迎光临</view>
    <view class="home-sub">请选择您的点餐方式</view>
  </view>

  <view class="weui-cells weui-cells_after-title">
    <view class="weui-cell weui-cell_access" hover-class="weui-cell_active" bindtap="scanDineIn">
      <view class="weui-cell__hd home-emoji">🍽️</view>
      <view class="weui-cell__bd">
        <view class="home-entry-name">堂食</view>
        <view class="home-entry-desc">扫码点餐 · 桌边享用</view>
      </view>
      <view class="weui-cell__ft weui-cell__ft_in-access"></view>
    </view>

    <view class="weui-cell weui-cell_access" hover-class="weui-cell_active" bindtap="chooseDelivery">
      <view class="weui-cell__hd home-emoji">🛵</view>
      <view class="weui-cell__bd">
        <view class="home-entry-name">外卖<text class="home-badge">即将上线</text></view>
        <view class="home-entry-desc">送货上门 · 在家品尝</view>
      </view>
      <view class="weui-cell__ft weui-cell__ft_in-access"></view>
    </view>
  </view>

  <!-- 底部 tabbar -->
  <view class="tabbar-fixed">
    <mp-tabbar list="{{tabbarList}}" current="{{tabbarCurrent}}" bindchange="tabChange" />
  </view>
</view>
