<!-- pages/profile/index.wxml -->
<view class="page">
  <!-- User Header -->
  <view class="user-header">
    <view class="avatar-box">
      <image wx:if="{{user.avatar}}" src="{{user.avatar}}" class="avatar" />
      <view wx:else class="avatar-placeholder">{{user.nickname ? user.nickname[0] : 'V'}}</view>
    </view>
    <view class="user-info">
      <view class="nickname">{{user.nickname || 'VIP会员'}}</view>
      <view class="user-desc">福利会员·随时消费随时返</view>
    </view>
  </view>

  <!-- Balance Card -->
  <view class="balance-card">
    <view class="balance-item">
      <view class="balance-label">可提现余额</view>
      <view class="balance-amount">¥{{balanceText}}</view>
    </view>
    <view class="balance-divider"></view>
    <view class="balance-item">
      <view class="balance-label">福利金</view>
      <view class="balance-amount gold">¥{{rewardBalanceText}}</view>
    </view>
  </view>

  <!-- Stats Row -->
  <view class="stats-row">
    <view class="stat-item">
      <view class="stat-value">{{todayRewardText}}</view>
      <view class="stat-label">今日收益</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{stats.invite_count}}</view>
      <view class="stat-label">邀请人数</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{totalInviteRewardText}}</view>
      <view class="stat-label">累计奖励</view>
    </view>
  </view>

  <!-- Tabs -->
  <view class="weui-tabs">
    <view class="weui-tabs__header">
      <view class="weui-tabs__item {{activeTab === 'orders' ? 'weui-tabs__item_on' : ''}}" bind:tap="switchTab" data-tab="orders">消费订单</view>
      <view class="weui-tabs__item {{activeTab === 'logs' ? 'weui-tabs__item_on' : ''}}" bind:tap="switchTab" data-tab="logs">收支明细</view>
    </view>
  </view>

  <!-- Tab Content: 收支明细 -->
  <view wx:if="{{activeTab === 'logs'}}" class="tab-content">
    <mp-cells>
      <view wx:for="{{logs}}" wx:key="id">
        <mp-cell>
          <view slot="title" class="log-cell">
            <view class="log-type">{{item.typeLabel}}</view>
            <view class="log-remark">{{item.remark}}</view>
          </view>
          <view slot="footer" class="log-amount {{item.amount < 0 ? 'minus' : 'plus'}}">{{item.amountText}}</view>
        </mp-cell>
      </view>
    </mp-cells>
    <view wx:if="{{logs.length === 0}}" class="empty-tip">暂无记录</view>
  </view>

  <!-- Tab Content: 消费订单 -->
  <view wx:if="{{activeTab === 'orders'}}" class="tab-content">
    <view wx:for="{{orders}}" wx:key="id" class="order-item card">
      <view class="order-header">
        <text class="order-no">{{item.order_no}}</text>
        <text class="order-status">{{item.statusText}}</text>
      </view>
      <view class="order-body">
        <view class="order-info">
          <text class="shop-name">店铺消费</text>
          <text class="order-time">{{item.dateText}}</text>
        </view>
        <view class="order-amount">
          <text class="amount">{{item.amountText}}</text>
        </view>
      </view>
      <!-- 订单明细 -->
      <view wx:if="{{item.items && item.items.length > 0}}" class="order-detail">
        <view wx:for="{{item.items}}" wx:for-item="oi" wx:key="id" class="detail-row">
          <text class="detail-name">{{oi.product_name}} x{{oi.quantity}}</text>
          <text class="detail-price">{{oi.subtotalText}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{orders.length === 0}}" class="empty-tip">暂无订单</view>
  </view>

  <!-- 底部tabbar -->
  <custom-tab-bar current="{{tabbar.current}}" bindchange="tabChange" list="{{tabbar.list}}" />
</view>