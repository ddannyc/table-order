/* pages/profile/index.wxss */
.user-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.avatar-box {
  position: relative;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 44rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.user-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.balance-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  margin-bottom: 24rpx;
}

.balance-item {
  flex: 1;
  text-align: center;
}

.balance-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.balance-amount {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.balance-amount.gold {
  color: #FFD700;
}

.stats-row {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  background: #eee;
}

.weui-tabs {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.weui-tabs__header {
  display: flex;
  padding: 8rpx;
}

.weui-tabs__item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #999;
  border-radius: 8rpx;
}

.weui-tabs__item_on {
  background: var(--weui-primary);
  color: #fff;
  font-weight: 600;
}

.tab-content {
  min-height: 600rpx;
}

.log-item {
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
}

.log-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.log-remark {
  font-size: 24rpx;
  color: #999;
}

.log-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.log-amount.plus {
  color: var(--weui-primary);
}

.log-amount.minus {
  color: #ff6b6b;
}

.order-item {
  margin-bottom: 24rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #fafafa;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  color: var(--weui-primary);
}

.order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 500;
}

.order-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.order-amount .amount {
  font-size: 32rpx;
  font-weight: 600;
}

.order-detail {
  padding: 16rpx 32rpx 24rpx;
  border-top: 2rpx solid #f0f0f0;
  background: #fafafa;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.detail-name {
  font-size: 24rpx;
  color: #666;
}

.detail-price {
  font-size: 24rpx;
  color: #666;
}

.reward-paused-bar {
  background: #fff3cd;
  color: #856404;
  padding: 20rpx 32rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.expiring-soon-bar {
  background: #f8d7da;
  color: #721c24;
  padding: 20rpx 32rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.reward-rules {
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.rule-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.rule-item {
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 0;
  padding-left: 16rpx;
  border-left: 4rpx solid var(--weui-primary);
  margin-bottom: 8rpx;
}