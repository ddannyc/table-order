/* pages/profile/index.wxss */

/* Profile skeleton */
.profile-skeleton {
  padding: 0 0 160rpx;
}
.sk-user-header {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  background: var(--color-bg-surface);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}
.sk-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, var(--color-bg-page) 25%, #e8e8e8 50%, var(--color-bg-page) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.sk-lines {
  flex: 1;
}
.sk-line {
  height: 24rpx;
  background: linear-gradient(90deg, var(--color-bg-page) 25%, #e8e8e8 50%, var(--color-bg-page) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}
.sk-line-short { width: 50%; }
.sk-line-xs { width: 35%; }
.sk-card {
  height: 120rpx;
  background: var(--color-bg-surface);
  border-radius: var(--space-md);
  margin-bottom: var(--space-md);
}
.sk-stats {
  height: 100rpx;
  background: var(--color-bg-surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}
.sk-tabs {
  height: 80rpx;
  background: var(--color-bg-surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}
.sk-row {
  height: 80rpx;
  background: var(--color-bg-surface);
  margin-bottom: var(--space-md);
  border-radius: var(--radius-md);
}

/* Error state */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 80rpx 40rpx;
}
.error-icon {
  width: 120rpx;
  height: 120rpx;
  background: var(--color-danger-bg);
  color: var(--color-danger-text);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  font-weight: bold;
  margin-bottom: var(--space-lg);
}
.error-title {
  font-size: var(--font-h2);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}
.error-desc {
  font-size: var(--font-body);
  color: var(--color-text-hint);
  margin-bottom: var(--space-xl);
  text-align: center;
}

.user-header {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  background: var(--color-bg-surface);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160 0%, #059a4c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-bg-surface);
  font-size: 44rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.user-desc {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
  margin-top: var(--space-xs);
}

.balance-card {
  background: linear-gradient(135deg, #059a4c 0%, #047a3d 100%);
  border-radius: var(--space-md);
  padding: 40rpx;
  display: flex;
  margin-bottom: var(--space-md);
}

.balance-item {
  flex: 1;
  text-align: center;
}

.balance-label {
  font-size: var(--font-caption);
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: var(--space-sm);
}

.balance-amount {
  font-size: var(--font-price-large);
  font-weight: bold;
  color: var(--color-bg-surface);
}

.balance-amount.gold {
  color: var(--color-gold);
}

.stats-row {
  display: flex;
  background: var(--color-bg-surface);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: var(--font-title);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
}

.stat-label {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
}

.stat-divider {
  width: 2rpx;
  background: var(--color-border-light);
}

.weui-tabs {
  background: var(--color-bg-surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}

.weui-tabs__header {
  display: flex;
  padding: var(--space-xs);
}

.weui-tabs__item {
  flex: 1;
  text-align: center;
  padding: var(--space-sm);
  font-size: var(--font-body);
  color: var(--color-text-hint);
  border-radius: var(--radius-sm);
}

.weui-tabs__item_on {
  background: var(--weui-primary);
  color: var(--color-bg-surface);
  font-weight: 600;
}

.tab-content {
  min-height: 600rpx;
}

.log-remark {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
}

.log-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.log-amount.plus {
  color: var(--weui-primary);
}

.log-amount.minus {
  color: #ff6b6b;
}

.order-item {
  margin-bottom: var(--space-md);
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding: 20rpx var(--space-lg);
  background: var(--color-bg-hover);
}

.order-no {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
}

.order-status {
  font-size: var(--font-caption);
  color: var(--weui-primary);
}

.order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
}

.order-info {
  display: flex;
  flex-direction: column;
}

.shop-name {
  font-size: var(--font-body);
  font-weight: 500;
}

.order-time {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
  margin-top: var(--space-xs);
}

.order-amount .amount {
  font-size: 32rpx;
  font-weight: 600;
}

.order-detail {
  padding: var(--space-sm) var(--space-lg) var(--space-md);
  border-top: 2rpx solid var(--color-border-light);
  background: var(--color-bg-hover);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xs) 0;
}

.detail-name {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.detail-price {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.reward-paused-bar {
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-sm);
}

.expiring-soon-bar {
  background: var(--color-danger-bg);
  color: var(--color-danger-text);
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-sm);
}

.reward-rules {
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}

.rule-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
}

.rule-item {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  padding: var(--space-xs) 0;
  padding-left: var(--space-sm);
  border-left: 4rpx solid var(--weui-primary);
  margin-bottom: var(--space-xs);
}