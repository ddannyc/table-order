/* pages/profile/index.wxss */
.user-header {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  background: #fff;
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--weui-BRAND);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 44rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--weui-FG-0);
}

.user-desc {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
  margin-top: var(--space-xs);
}

.balance-card {
  background: var(--weui-BRAND);
  border-radius: var(--space-md);
  padding: 40rpx;
  display: flex;
  margin-bottom: var(--space-md);
}

.balance-item {
  flex: 1;
  text-align: center;
}

.balance-label {
  font-size: var(--font-caption);
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: var(--space-sm);
}

.balance-amount {
  font-size: var(--font-price-large);
  font-weight: bold;
  color: #fff;
}

.balance-amount.gold {
  color: #fff;
}

.stats-row {
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: var(--font-title);
  font-weight: bold;
  color: var(--weui-FG-0);
  margin-bottom: var(--space-xs);
}

.stat-label {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.stat-divider {
  width: 2rpx;
  background: var(--weui-FG-3);
}

.weui-tabs {
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}

.weui-tabs__header {
  display: flex;
  padding: var(--space-xs);
}

.weui-tabs__item {
  flex: 1;
  text-align: center;
  padding: var(--space-sm);
  font-size: var(--font-body);
  color: var(--weui-FG-2);
  border-radius: var(--radius-sm);
}

.weui-tabs__item_on {
  background: var(--weui-BRAND);
  color: #fff;
  font-weight: 600;
}

.tab-content {
  min-height: 600rpx;
}

.log-remark {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.log-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.log-amount.plus {
  color: var(--weui-BRAND);
}

.log-amount.minus {
  color: var(--weui-RED);
}

.order-item {
  margin-bottom: var(--space-md);
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding: 20rpx var(--space-lg);
  background: var(--weui-BG-1);
}

.order-no {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.order-status {
  font-size: var(--font-caption);
  color: var(--weui-BRAND);
}

.order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
}

.order-info {
  display: flex;
  flex-direction: column;
}

.shop-name {
  font-size: var(--font-body);
  font-weight: 500;
}

.order-time {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
  margin-top: var(--space-xs);
}

.order-amount .amount {
  font-size: 32rpx;
  font-weight: 600;
}

.order-detail {
  padding: var(--space-sm) var(--space-lg) var(--space-md);
  border-top: 2rpx solid var(--weui-FG-3);
  background: var(--weui-BG-1);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xs) 0;
}

.detail-name {
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
}

.detail-price {
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
}

.reward-paused-bar {
  background: var(--weui-BG-1);
  color: var(--weui-FG-1);
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-sm);
}

.expiring-soon-bar {
  background: var(--weui-BG-1);
  color: var(--weui-RED);
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-sm);
}

.reward-rules {
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}

.rule-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--weui-FG-0);
  margin-bottom: var(--space-sm);
}

.rule-item {
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
  padding: var(--space-xs) 0;
  padding-left: var(--space-sm);
  border-left: 4rpx solid var(--weui-BRAND);
  margin-bottom: var(--space-xs);
}

/* 未登录：用户名点击登录 */
.login-link {
  color: var(--weui-BRAND);
}

/* 未登录：福利金灰色 */
.balance-amount.muted {
  color: rgba(255, 255, 255, 0.6);
}

/* 未登录：tab 内容区登录提示 */
.login-tip-inline {
  text-align: center;
  padding: 80rpx 48rpx;
}

.login-tip-text {
  display: block;
  font-size: var(--font-body);
  color: var(--weui-FG-2);
  margin-bottom: var(--space-lg);
}

.login-tip-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: var(--weui-BRAND);
  color: #fff;
  font-size: var(--font-body);
  border-radius: var(--radius-sm);
}
