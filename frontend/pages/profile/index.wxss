/* pages/profile/index.wxss */
.user-header {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  background: linear-gradient(160deg, var(--weui-BRAND), var(--green-2)); /* 品牌粉渐变页头，对齐设计稿 */
  padding: var(--space-lg);
  padding-top: calc(var(--space-lg) + env(safe-area-inset-top));
  margin-bottom: var(--space-md);
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--accent); /* 黄底字标头像，对齐设计稿 */
  border: 2rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--weui-BRAND);
  font-size: 44rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: var(--font-title);
  font-weight: 600;
  color: #fff;
}

.user-desc {
  font-size: var(--font-caption);
  color: rgba(255, 255, 255, 0.85);
  margin-top: var(--space-xs);
}

.balance-card {
  background: linear-gradient(120deg, var(--jf-gold-bg-0), var(--jf-gold-bg-1)); /* 金卡渐变，对齐设计稿 */
  border: 1rpx solid var(--jf-gold-line);
  border-radius: var(--space-md);
  padding: 40rpx;
  display: flex;
  margin-bottom: var(--space-md);
  box-shadow: 0 10rpx 28rpx rgba(232, 161, 0, 0.18);
}

.balance-item {
  flex: 1;
  text-align: center;
}

.balance-label {
  font-size: var(--font-caption);
  color: var(--jf-gold-ink); /* 深琥珀，金底达标 */
  margin-bottom: var(--space-sm);
}

.balance-amount {
  font-size: var(--font-price-large);
  font-weight: bold;
  font-family: var(--font-number);
  color: var(--jf-gold-ink);
}

.balance-amount.gold {
  color: var(--jf-gold-ink); /* 金底深琥珀 5.1:1，过 AA */
}

.balance-amount.muted {
  color: rgba(138, 85, 0, 0.5); /* 未登录占位，减弱但仍可读 */
}

.stats-row {
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: var(--font-title);
  font-weight: bold;
  font-family: var(--font-number);
  color: var(--weui-FG-0);
  margin-bottom: var(--space-xs);
}

.stat-label {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.stat-divider {
  width: 2rpx;
  background: var(--weui-FG-3);
}

.weui-tabs {
  background: transparent;
  margin: 0 var(--space-md) var(--space-md);
}

.weui-tabs__header {
  display: flex;
  padding: 0;
  border-bottom: 1rpx solid var(--weui-FG-3);
}

.weui-tabs__item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: var(--font-body);
  font-weight: 700;
  color: var(--weui-FG-2);
  position: relative;
}

.weui-tabs__item_on {
  background: transparent;
  color: var(--weui-BRAND);
  font-weight: 900;
}

/* 激活态粉色下划线条（对齐设计稿 ptab.on::after） */
.weui-tabs__item_on::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -1rpx;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--weui-BRAND);
}

.tab-content {
  min-height: 600rpx;
}

.log-remark {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.log-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.log-amount.plus {
  color: var(--green-2); /* 深粉：收入，小字 on 卡 4.88:1 过 AA（亮粉 --weui-BRAND 仅 3.1） */
}

.log-amount.minus {
  color: var(--price-ink); /* 价格红：支出，5.41:1 */
}

.order-item {
  margin-bottom: var(--space-md);
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding: 20rpx var(--space-lg);
  background: var(--weui-BG-1);
}

.order-no {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
}

.order-status {
  font-size: var(--font-caption);
  color: var(--weui-BRAND);
}

.order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
}

.order-info {
  display: flex;
  flex-direction: column;
}

.shop-name {
  font-size: var(--font-body);
  font-weight: 500;
}

.order-time {
  font-size: var(--font-caption);
  color: var(--weui-FG-2);
  margin-top: var(--space-xs);
}

.order-amount .amount {
  font-size: 32rpx;
  font-weight: 600;
}

.order-detail {
  padding: var(--space-sm) var(--space-lg) var(--space-md);
  border-top: 2rpx solid var(--weui-FG-3);
  background: var(--weui-BG-1);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xs) 0;
}

.detail-name {
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
}

.detail-price {
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
}

.reward-paused-bar {
  background: var(--weui-BG-1);
  color: var(--weui-FG-1);
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-sm);
}

.expiring-soon-bar {
  background: var(--weui-BG-1);
  color: var(--price-ink); /* 价格红：警示文字小字过 AA（weui-RED on 近白仅 ~3.3） */
  padding: 20rpx var(--space-lg);
  font-size: var(--font-caption);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-sm);
}

.reward-rules {
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}

.rule-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--weui-FG-0);
  margin-bottom: var(--space-sm);
}

.rule-item {
  font-size: var(--font-caption);
  color: var(--weui-FG-1);
  padding: var(--space-xs) 0;
  padding-left: var(--space-sm);
  border-left: 4rpx solid var(--weui-BRAND);
  margin-bottom: var(--space-xs);
}

/* 未登录：用户名点击登录 */
.login-link {
  color: var(--weui-BRAND);
}

/* 未登录：福利金灰色 */
.balance-amount.muted {
  color: rgba(255, 255, 255, 0.6);
}

/* 未登录：tab 内容区登录提示 */
.login-tip-inline {
  text-align: center;
  padding: 80rpx 48rpx;
}

.login-tip-text {
  display: block;
  font-size: var(--font-body);
  color: var(--weui-FG-2);
  margin-bottom: var(--space-lg);
}

.login-tip-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: var(--weui-BRAND);
  color: #fff;
  font-size: var(--font-body);
  border-radius: var(--radius-sm);
}
