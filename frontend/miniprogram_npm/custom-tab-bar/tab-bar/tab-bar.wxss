.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #e5e5e5;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  min-height: 100rpx;
}

.tab-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.icon-emoji {
  font-size: 48rpx;
  line-height: 1;
  transition: transform 0.2s;
}

.icon-text {
  font-size: 22rpx;
  color: #999;
  transition: color 0.2s;
}

.tab-item.active .icon-emoji {
  transform: scale(1.15);
}

.tab-item.active .icon-text,
.icon-text.active {
  color: #07c160;
  font-weight: 600;
}

.icon-emoji:not(.active) {
  filter: grayscale(100%) opacity(0.45);
}

.tab-item.active .icon-emoji {
  filter: none;
}