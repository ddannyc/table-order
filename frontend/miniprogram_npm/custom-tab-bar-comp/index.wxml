<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="key"
    class="tab-item {{current === index ? 'active' : ''}}"
    bindtap="switchTab"
    data-index="{{index}}"
  >
    <view class="tab-icon">
      <text class="icon-emoji {{current === index ? 'active' : ''}}">{{icons[index]}}</text>
      <text class="icon-text {{current === index ? 'active' : ''}}">{{item.text}}</text>
    </view>
  </view>
</view>