.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: var(--color-bg-surface);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) 0;
  min-height: 100rpx;
}

.tab-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.icon-emoji {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50%;
  background: var(--color-border-light);
  color: var(--color-text-hint);
  transition: all 0.2s;
}

.icon-text {
  font-size: var(--font-caption);
  color: var(--color-text-hint);
  transition: color 0.2s;
}

.tab-item.active .icon-emoji {
  background: var(--weui-primary-light);
  color: var(--weui-primary);
  transform: scale(1.1);
}

.tab-item.active .icon-text,
.icon-text.active {
  color: var(--weui-primary);
  font-weight: 600;
}