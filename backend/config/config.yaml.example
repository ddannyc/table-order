server:
  port: "8080"
  mode: debug

database:
  host: localhost
  port: "5432"
  user: postgres
  password: your_db_password
  dbname: table_order

redis:
  host: localhost
  port: "6379"
  password: ""
  db: 0

jwt:
  secret: your-jwt-secret
  expire_hours: 720

wechat:
  appid: "your-wechat-appid"
  appsecret: "your-wechat-appsecret"
  # WeChat Pay V3
  mch_id: "your-mch-id"
  mch_certificate_serial_number: "your-cert-serial"
  mch_private_key_path: "./tmp/apiclient_key.pem"
  mch_api_v3_key: "your-api-v3-key"
  pay_notify_url: "https://your-domain.com/api/orders/notify"
  # Public key scheme (required since 2026)
  wechatpay_public_key_id: "PUB_KEY_ID_xxxxxxxx"
  wechatpay_public_key_path: "./tmp/pub_key.pem"

# 闪送开放平台（外卖配送）
# Env overrides: SHANSONG_CLIENT_ID / SHANSONG_APP_SECRET / SHANSONG_BASE_URL / SHANSONG_NOTIFY_URL
# 凭据由商家在闪送应用中心申请，切勿提交真实密钥
shansong:
  clientid: "your-shansong-clientid"
  appsecret: "your-shansong-appsecret"
  shop_id: "your-shansong-shop-id"             # 商家门店号（系统参数 shopId）
  base_url: "https://open.s.bingex.com"        # 测试环境；生产 https://open.ishansong.com
  notify_url: "https://your-domain.com/api/shansong/callback"

# Cloudflare R2 (object storage for merchant product images)
# Env overrides: R2_ACCOUNT_ID / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY / R2_BUCKET / R2_PUBLIC_BASE
r2:
  account_id: "your-r2-account-id"            # endpoint = https://<account_id>.r2.cloudflarestorage.com
  access_key_id: "your-r2-access-key-id"      # from "Create Account API Token" (S3 credentials)
  secret_access_key: "your-r2-secret-access-key"
  bucket: "table-order-images"
  public_base: "https://bestluckbox.com"      # custom domain for reads; Image = public_base + "/" + objectKey
